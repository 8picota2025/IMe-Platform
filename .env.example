# Supabase (proyecto en supabase.com) — TODO_CLIENTE
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # SOLO en Edge Functions

# LLM / IA — TODO_CLIENTE
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
VOYAGE_API_KEY=
LLM_PROVIDER=anthropic
LLM_CHAT_MODEL=claude-sonnet-4-6
LLM_INGEST_MODEL=claude-sonnet-4-6
BUDGET_MENSUAL_USD=50

# Embeddings Asesor RAG — cambiar provider/dim implica re-embeber todo el catalogo
EMBEDDING_PROVIDER=voyage
EMBEDDING_MODEL=voyage-3
EMBEDDING_DIM=1024

# Ollama (desarrollo local, sin credenciales, coste $0) — ver
# docs/decisions/0005-ollama-asesor-local.md. Si `supabase functions serve`
# corre en Docker y Ollama en el host, cambia localhost por
# http://172.17.0.1:11434 (bridge Linux) o http://host.docker.internal:11434.
OLLAMA_BASE_URL=http://localhost:11434
# Alternativa local sin credenciales (desarrollo):
# LLM_PROVIDER=ollama
# LLM_CHAT_MODEL=qwen3:8b
# LLM_INGEST_MODEL=qwen3:8b
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_MODEL=mxbai-embed-large
# EMBEDDING_DIM=1024

# Pagos Colombia — TODO_CLIENTE
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_EVENTS_SECRET=
WOMPI_INTEGRITY_SECRET=   # "secreto de integridad" del dashboard Wompi (distinto de WOMPI_PRIVATE_KEY), firma el Web Checkout hospedado

# Pagos Internacional — TODO_CLIENTE
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Anti-bot — TODO_CLIENTE
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
PUBLIC_TURNSTILE_SITE_KEY=   # mismo valor que TURNSTILE_SITE_KEY, expuesto al cliente para el widget Asesor

# Rate-limit Asesor (ventana corta anti-burst + tope diario)
ASESOR_RATE_LIMIT_VENTANA_SEGUNDOS=60
ASESOR_RATE_LIMIT_MAX_VENTANA=8
ASESOR_RATE_LIMIT_MAX_DIA=60

# Rate-limit crear-pago (10/hora/IP — F4.1, docs/decisions/0001-rate-limit-crear-pago.md)
CREAR_PAGO_RATE_LIMIT_VENTANA_SEGUNDOS=3600
CREAR_PAGO_RATE_LIMIT_MAX_VENTANA=10
CREAR_PAGO_RATE_LIMIT_MAX_DIA=30

# notificar-proveedor, canal email — TODO_CLIENTE (estilo Resend; sin esto, canal='email' queda en estado 'error' con mensaje accionable)
MAILER_API_KEY=
MAILER_FROM=

# CI/CD Deploy — TODO_CLIENTE
CI_DEPLOY_HOOK=
