{
  "name": "ime-platform",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev --host 0.0.0.0 --port 43421",
    "build": "astro build",
    "preview": "astro preview --port 43421",
    "check": "astro check",
    "lint": "eslint src --max-warnings 0",
    "format": "prettier --write src",
    "validate": "npm run lint && npm run check && npm run build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,astro}": [
      "eslint --fix --max-warnings 0"
    ],
    "*.{ts,tsx,astro,css,md,json}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "astro": "^6.4.4"
  },
  "devDependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "eslint-plugin-astro": "^1.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
