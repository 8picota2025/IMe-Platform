{
  "name": "ime-platform",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["packages/*"],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev --host 0.0.0.0 --port 44334",
    "build": "astro build",
    "preview": "astro preview --host 0.0.0.0 --port 44334",
    "check": "astro check",
    "lint": "eslint src packages --max-warnings 0",
    "format": "prettier --write src packages",
    "test": "vitest run",
    "test:watch": "vitest",
    "import:gmd": "node --env-file=.env scripts/import-gmd-catalog.mjs",
    "import:gmd-images": "node --env-file=.env scripts/persist-gmd-images.mjs",
    "validate": "npm run lint && npm run check && npm run test && npm run build",
    "validate:all": "npm run validate && npm run -w @ime/shared lint && npm run -w @ime/shared check && npm run -w @ime/config lint",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,astro}": ["eslint --fix --max-warnings 0"],
    "*.{ts,tsx,astro,css,md,json}": ["prettier --write"]
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@supabase/supabase-js": "^2.108.0",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.4.4",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "pdfjs-dist": "^6.0.227",
    "xlsx": "0.18.5"
  },
  "devDependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.4.1",
    "eslint-plugin-astro": "^1.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.9"
  }
}
