---
/**
 * Servicios ES — contenido real de contenido_ime.json.servicios
 */
import Layout from '../../layouts/Layout.astro'
import { buildPageTitle, buildCanonical } from '../../lib/seo'

const locale = 'es'
const title = buildPageTitle('Servicios Especializados — Soporte Biomédico')
const description =
  'Venta y distribución, soporte técnico, financiamiento médico y asesoría biomédica para hospitales y clínicas en Colombia.'
const canonical = buildCanonical('/es/servicios')

const servicios = [
  {
    num: '01',
    titulo: 'Venta y distribución',
    desc: 'Distribución de equipos biomédicos de alta tecnología con certificaciones internacionales CE, FDA e INVIMA para hospitales, clínicas y centros de salud en Colombia.',
    items: [
      'Equipos certificados internacionalmente',
      'Asesoría técnica especializada precompra',
      'Instalación y puesta en marcha incluida',
    ],
    img: '/assets/extraccion/img/Img11.jpg',
  },
  {
    num: '02',
    titulo: 'Soporte técnico',
    desc: 'Mantenimiento preventivo, correctivo y calibración de equipos biomédicos realizado por ingenieros certificados en todo el territorio colombiano.',
    items: [
      'Mantenimiento preventivo y correctivo',
      'Calibración y verificación metrológica',
      'Repuestos y consumibles originales',
    ],
    img: '/assets/extraccion/img/Img4.jpg',
  },
  {
    num: '03',
    titulo: 'Financiamiento médico',
    desc: 'Planes de adquisición a medida para instituciones de salud. Cuotas flexibles, plazos extendidos y condiciones adaptadas a las necesidades de cada organización.',
    items: [
      'Cuotas mensuales flexibles',
      'Plazos hasta 60 meses',
      'Sin codeudor para instituciones de salud',
    ],
    img: '/assets/extraccion/img/Img27.jpg',
  },
  {
    num: '04',
    titulo: 'Asesoría biomédica',
    desc: 'Consultoría especializada para la correcta selección, adquisición y gestión del parque tecnológico biomédico de su institución de salud.',
    items: [
      'Diagnóstico del parque tecnológico',
      'Plan de renovación y adquisición',
      'Capacitación al personal clínico',
    ],
    img: '/assets/extraccion/img/Img25.jpg',
  },
]
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  locale={locale}
  currentPath="/es/servicios"
>
  <div
    class="page-hero"
    style="padding-top:130px;padding-bottom:var(--space-2xl);background:var(--off)"
  >
    <div class="container">
      <span class="section-tag">Servicios</span>
      <h1>Servicios especializados</h1>
      <p style="color:var(--text-mid);max-width:560px;margin:0.75rem 0 0">
        Soluciones integrales desde la adquisición hasta el soporte técnico de largo plazo para
        instituciones de salud.
      </p>
    </div>
  </div>

  <section class="section container">
    <ul class="servicios-list" role="list">
      {
        servicios.map((s, i) => (
          <li
            class:list={['servicio-row', { 'servicio-row--reverse': i % 2 !== 0 }]}
            id={`servicio-${s.num}`}
          >
            <div class="servicio-row__img">
              <img
                src={s.img}
                alt=""
                width="560"
                height="380"
                loading="lazy"
                decoding="async"
                class="servicio-row__photo"
                aria-hidden="true"
              />
            </div>
            <div class="servicio-row__content">
              <span class="servicio-num" aria-hidden="true">
                {s.num}
              </span>
              <h2 class="servicio-titulo">{s.titulo}</h2>
              <p class="servicio-desc">{s.desc}</p>
              <ul class="servicio-items" role="list">
                {s.items.map((item) => (
                  <li>
                    <span aria-hidden="true">✓</span> {item}
                  </li>
                ))}
              </ul>
              <a
                href="/es/contacto"
                class="btn btn-primary"
                style="align-self:flex-start;margin-top:0.5rem"
              >
                Consultar este servicio
              </a>
            </div>
          </li>
        ))
      }
    </ul>
  </section>
</Layout>

<style>
  .section-tag {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--t900);
    background: var(--t100);
    padding: 0.3rem 0.875rem;
    border-radius: 999px;
    margin-block-end: 0.75rem;
  }
  .servicios-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }
  .servicio-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: center;
  }
  @media (min-width: 900px) {
    .servicio-row {
      grid-template-columns: 1fr 1fr;
    }
    .servicio-row--reverse .servicio-row__img {
      order: 2;
    }
  }
  .servicio-row__photo {
    border-radius: var(--radius-lg);
    width: 100%;
    height: auto;
    object-fit: cover;
    box-shadow: var(--shadow-lg);
  }
  .servicio-row__content {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .servicio-num {
    font-family: var(--font-display);
    font-size: var(--step-4);
    font-weight: 800;
    color: var(--t100);
    line-height: 1;
  }
  .servicio-titulo {
    font-size: var(--step-2);
    font-weight: 700;
    color: var(--ink);
    margin: 0;
  }
  .servicio-desc {
    color: var(--text-mid);
    margin: 0;
    line-height: 1.6;
  }
  .servicio-items {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .servicio-items li {
    display: flex;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--text);
  }
  .servicio-items span {
    color: var(--green);
    font-weight: 700;
    flex-shrink: 0;
  }
</style>
