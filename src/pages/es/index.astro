---
/**
 * Home ES — réplica visual FIEL del sitio en producción (https://i-me.com.co/).
 * Estructura, textos, fotos, colores, tipografía, espaciados y animaciones
 * portados 1:1 desde index.html de producción (CSS en styles/site-faithful.css).
 *
 * Se conservan los componentes nuevos del Layout (Navbar, Footer, CotizacionDrawer,
 * Carrito, Asesor). Los botones de catálogo/cotización apuntan a las
 * funciones nuevas: catálogo → /es/catalogo, productos → /es/productos/[slug],
 * "Cotizar" → drawer de cotización nuevo.
 */
import Layout from '../../layouts/Layout.astro';
import { getProductosDestacados } from '../../lib/datos';
import {
  buildFaqJsonLd,
  buildHomeSeo,
  buildOrganizationJsonLd,
  buildWebSiteJsonLd,
  combineJsonLd,
} from '../../lib/seo';
import contenidoIme from '../../data/contenido_ime.json';
import '../../styles/site-faithful.css';

const locale = 'es';
const seo = buildHomeSeo(locale);
const faqData = contenidoIme.home.faq.es;
const jsonLd = combineJsonLd(
  buildOrganizationJsonLd(),
  buildWebSiteJsonLd(),
  buildFaqJsonLd(faqData)
);

const productosDestacados = await getProductosDestacados(locale);

// Categorías — réplica fiel de las 8 cat-card de producción
const categorias = [
  {
    slug: 'monitores',
    icon: 'fa-heartbeat',
    nombre: 'Monitores',
    count: 'Multiparamétricos · UCI',
    bg: 'https://images.unsplash.com/photo-1559757175-5700dde675bc?w=400&q=70&auto=format&fit=crop',
    aria: 'Ver monitores multiparamétricos',
  },
  {
    slug: 'cardiologia',
    icon: 'fa-wave-square',
    nombre: 'Cardiología',
    count: 'ECG · Holter · Desfibriladores',
    bg: 'https://images.unsplash.com/photo-1530026405186-ed1f139313f8?w=400&q=70&auto=format&fit=crop',
    aria: 'Ver equipos de cardiología',
  },
  {
    slug: 'sala-cirugia',
    icon: 'fa-user-md',
    nombre: 'Sala de Cirugía',
    count: 'Mesas · Lámparas · Bisturí',
    bg: 'https://images.unsplash.com/photo-1551190822-a9333d879b1f?w=400&q=70&auto=format&fit=crop',
    aria: 'Ver equipos de sala de cirugía',
  },
  {
    slug: 'neonatologia',
    icon: 'fa-baby',
    nombre: 'Neonatología',
    count: 'Incubadoras · Cunas · CPAP',
    bg: 'https://images.unsplash.com/photo-1631815588090-d4bfec5b1ccb?w=400&q=70&auto=format&fit=crop',
    aria: 'Ver equipos de neonatología',
  },
  {
    slug: 'ultrasonido',
    icon: 'fa-satellite-dish',
    nombre: 'Ultrasonido',
    count: 'Color Doppler · Portátil',
    bg: 'https://images.unsplash.com/photo-1516549655669-df64f2a0aafb?w=400&q=70&auto=format&fit=crop',
    aria: 'Ver equipos de ultrasonido',
  },
  {
    slug: 'soluciones-iv',
    icon: 'fa-syringe',
    nombre: 'Soluciones IV',
    count: 'Bombas de infusión · Jeringa',
    bg: 'https://images.unsplash.com/photo-1585435557343-3b092031a831?w=400&q=70&auto=format&fit=crop',
    aria: 'Ver bombas de infusión',
  },
  {
    slug: 'mobiliario',
    icon: 'fa-bed',
    nombre: 'Mobiliario',
    count: 'Camillas · Sillas · Coches',
    bg: 'https://images.unsplash.com/photo-1519494026892-80bbd2d6fd0d?w=400&q=70&auto=format&fit=crop',
    aria: 'Ver mobiliario hospitalario',
  },
  {
    slug: 'anestesia',
    icon: 'fa-lungs',
    nombre: 'Anestesia',
    count: 'Máquinas · Ventiladores',
    bg: 'https://images.unsplash.com/photo-1584820927498-cfe5211fd8bf?w=400&q=70&auto=format&fit=crop',
    aria: 'Ver equipos de anestesia',
  },
];

// Servicios — réplica fiel de las 4 svc-row de producción
const servicios = [
  {
    num: '01',
    icon: 'fa-boxes-stacking',
    titulo: 'Venta y distribución',
    desc: 'Distribución de equipos biomédicos de alta tecnología con certificaciones internacionales CE, FDA e INVIMA para hospitales, clínicas y centros de salud en Colombia.',
    items: [
      'Equipos certificados internacionalmente',
      'Asesoría técnica especializada precompra',
      'Instalación y puesta en marcha incluida',
    ],
  },
  {
    num: '02',
    icon: 'fa-screwdriver-wrench',
    titulo: 'Soporte técnico',
    desc: 'Mantenimiento preventivo, correctivo y calibración de equipos biomédicos realizado por ingenieros certificados en todo el territorio colombiano.',
    items: [
      'Mantenimiento preventivo y correctivo',
      'Calibración y verificación metrológica',
      'Repuestos y consumibles originales',
    ],
  },
  {
    num: '03',
    icon: 'fa-coins',
    titulo: 'Financiamiento médico',
    desc: 'Planes de adquisición a medida para instituciones de salud. Cuotas flexibles, plazos extendidos y condiciones adaptadas a las necesidades de cada organización.',
    items: [
      'Cuotas mensuales flexibles',
      'Plazos hasta 60 meses',
      'Sin codeudor para instituciones de salud',
    ],
  },
  {
    num: '04',
    icon: 'fa-user-tie',
    titulo: 'Asesoría biomédica',
    desc: 'Consultoría especializada para la correcta selección, adquisición y gestión del parque tecnológico biomédico de su institución de salud.',
    items: [
      'Diagnóstico del parque tecnológico',
      'Plan de renovación y adquisición',
      'Capacitación al personal clínico',
    ],
  },
];
---

<Layout
  title={seo.title}
  description={seo.description}
  canonical={seo.canonical}
  locale={locale}
  currentPath="/es/"
  ogImage={seo.ogImage}
  jsonLd={jsonLd}
  fontAwesome={true}
>
  <div class="site-faithful">
    <!-- ═══ HERO ═══ -->
    <section class="hero" aria-labelledby="hero-h1">
      <div class="hero-video-bg" aria-hidden="true">
        <video
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          poster="/assets/img/quirofanos-inteligentes.webp"
          aria-label="Quirófano inteligente en funcionamiento — I-ME International Medical Enterprise Colombia"
        >
          <source
            src="/assets/video/quirofano-completo.mp4"
            type="video/mp4"
            media="(min-width: 768px)"
          />
        </video>
      </div>
      <div class="hero-overlay" aria-hidden="true"></div>

      <div class="hero-inner">
        <div class="hero-left">
          <div class="hero-kicker">
            <i class="fas fa-circle-check" style="font-size:9px;color:var(--green)"></i>
            Distribuidor Certificado · Colombia
          </div>
          <h1 id="hero-h1" class="hero-title">
            Equipos <span class="hl">biomédicos</span> que salvan vidas
          </h1>
          <p class="hero-sub">
            Distribuimos tecnología médica de clase mundial certificada internacionalmente para
            hospitales, clínicas y centros de salud en todo Colombia.
          </p>
          <div class="hero-actions">
            <a href="/es/catalogo" class="btn btn-primary">
              <i class="fas fa-microscope"></i> Ver catálogo
            </a>
            <a href="/es/contacto" class="btn btn-outline-white"> Solicitar asesoría </a>
          </div>
          <div class="hero-stats">
            <div>
              <div class="stat-n" data-count="24" data-suffix="+">24+</div>
              <div class="stat-l">Categorías de equipos</div>
            </div>
            <div>
              <div class="stat-n" data-count="100" data-suffix="%">100%</div>
              <div class="stat-l">Certificados INVIMA</div>
            </div>
            <div>
              <div class="stat-n" data-count="32" data-suffix=" Dpt">32 Dpt</div>
              <div class="stat-l">Cobertura nacional</div>
            </div>
          </div>
        </div>

        <div class="hero-right-panel" aria-hidden="true">
          <div class="hero-product-img">
            <img
              src="/assets/img/equipos-biomedicos-vanguardia-opt.webp"
              alt="Tecnología biomédica de vanguardia — I-ME Colombia"
              width="460"
              height="380"
            />
          </div>
          <div class="hero-badge-overlay">
            <div class="hbo-n">+15</div>
            <div class="hbo-l">Años de experiencia</div>
          </div>
        </div>
      </div>

      <div class="hero-ecg-wrap" aria-hidden="true">
        <svg viewBox="0 0 1200 60" fill="none" preserveAspectRatio="none">
          <polyline
            points="0,30 100,30 120,10 140,50 155,30 200,30 260,30 280,8 295,52 310,30 400,30 460,30 480,5 500,55 515,30 600,30 700,30 720,10 740,50 755,30 800,30 860,30 880,8 895,52 910,30 1000,30 1060,30 1080,5 1100,55 1115,30 1200,30"
            stroke="rgba(126,217,87,0.55)"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></polyline>
          <polyline
            points="0,30 100,30 120,10 140,50 155,30 200,30 260,30 280,8 295,52 310,30 400,30 460,30 480,5 500,55 515,30 600,30 700,30 720,10 740,50 755,30 800,30 860,30 880,8 895,52 910,30 1000,30 1060,30 1080,5 1100,55 1115,30 1200,30"
            stroke="rgba(126,217,87,0.55)"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            transform="translate(1200,0)"></polyline>
        </svg>
      </div>
    </section>

    <!-- ═══ MARQUEE ═══ -->
    <div class="marquee" aria-hidden="true">
      <div class="marquee-track">
        <span class="marquee-item"><i class="fas fa-circle"></i> ISO 13485</span>
        <span class="marquee-item"><i class="fas fa-circle"></i> Certificación CE</span>
        <span class="marquee-item"><i class="fas fa-circle"></i> Registro INVIMA</span>
        <span class="marquee-item"><i class="fas fa-circle"></i> FDA Cleared</span>
        <span class="marquee-item"><i class="fas fa-circle"></i> Soporte Técnico Certificado</span>
        <span class="marquee-item"><i class="fas fa-circle"></i> Garantía Internacional</span>
        <span class="marquee-item"><i class="fas fa-circle"></i> Cobertura Nacional</span>
        <span class="marquee-item"><i class="fas fa-circle"></i> Financiamiento Médico</span>
        <span class="marquee-item"><i class="fas fa-circle"></i> ISO 13485</span>
        <span class="marquee-item"><i class="fas fa-circle"></i> Certificación CE</span>
        <span class="marquee-item"><i class="fas fa-circle"></i> Registro INVIMA</span>
        <span class="marquee-item"><i class="fas fa-circle"></i> FDA Cleared</span>
        <span class="marquee-item"><i class="fas fa-circle"></i> Soporte Técnico Certificado</span>
        <span class="marquee-item"><i class="fas fa-circle"></i> Garantía Internacional</span>
        <span class="marquee-item"><i class="fas fa-circle"></i> Cobertura Nacional</span>
        <span class="marquee-item"><i class="fas fa-circle"></i> Financiamiento Médico</span>
      </div>
    </div>

    <!-- ═══ ABOUT ═══ -->
    <section class="section" id="quienes-somos" aria-labelledby="about-h2">
      <div class="container">
        <div class="about-grid">
          <div class="about-imgs fade-in">
            <a
              href="/es/servicios"
              class="founder-link"
              aria-label="Conoce nuestro equipo y servicios"
            >
              <div class="about-img-main founder-card">
                <img
                  src="/assets/img/javier-fundador-ime.png"
                  alt="Javier, Fundador de I-ME — especialista en distribución de equipos biomédicos certificados en Colombia"
                  width="480"
                  height="640"
                  loading="eager"
                  decoding="async"
                />
                <div class="founder-card-label">
                  <strong>Javier</strong>
                  <span>Fundador · I-ME International Medical Enterprise</span>
                </div>
              </div>
            </a>
          </div>
          <div class="about-text fade-in d2">
            <div class="s-label">Quiénes somos</div>
            <h2 id="about-h2" class="s-title">
              Tecnología médica que transforma instituciones de salud
            </h2>
            <p>
              I-ME International Medical Enterprise es una empresa colombiana con más de 15 años de
              experiencia en la distribución, instalación y mantenimiento de equipos biomédicos de
              alta tecnología para el sector salud.
            </p>
            <p>
              Trabajamos con los principales fabricantes del mundo para llevar soluciones
              certificadas internacionalmente a hospitales, clínicas, centros médicos y consultorios
              en todo el territorio colombiano.
            </p>
            <div class="mv-grid">
              <div class="mv-card">
                <h4><i class="fas fa-eye" aria-hidden="true"></i> Visión</h4>
                <p>
                  Ser la empresa líder en Colombia en distribución de tecnología biomédica de
                  vanguardia.
                </p>
              </div>
              <div class="mv-card">
                <h4><i class="fas fa-bullseye" aria-hidden="true"></i> Misión</h4>
                <p>
                  Equipar las instituciones de salud con tecnología certificada que mejore la
                  atención al paciente.
                </p>
              </div>
              <div class="mv-card">
                <h4><i class="fas fa-award" aria-hidden="true"></i> Calidad</h4>
                <p>Todos nuestros equipos cuentan con certificaciones CE, FDA e INVIMA vigentes.</p>
              </div>
              <div class="mv-card">
                <h4><i class="fas fa-handshake" aria-hidden="true"></i> Compromiso</h4>
                <p>Soporte técnico especializado durante toda la vida útil de cada equipo.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ VALUES ═══ -->
    <section class="section section-off" aria-labelledby="values-h2">
      <div class="container">
        <div class="s-header s-header-center fade-in">
          <div class="s-label">Nuestros valores</div>
          <h2 id="values-h2" class="s-title">Por qué confiar en I-ME</h2>
          <p class="s-sub">
            Combinamos experiencia técnica, respaldo internacional y servicio posventa para ofrecer
            la mejor solución biomédica a cada institución.
          </p>
        </div>
        <div class="values-grid">
          <div class="val-card fade-in">
            <div class="val-icon"><i class="fas fa-certificate" aria-hidden="true"></i></div>
            <h3>Certificación</h3>
            <p>
              Equipos con registros INVIMA y certificaciones CE/FDA vigentes para operación legal en
              Colombia.
            </p>
          </div>
          <div class="val-card fade-in d1">
            <div class="val-icon"><i class="fas fa-tools" aria-hidden="true"></i></div>
            <h3>Soporte técnico</h3>
            <p>
              Equipo de ingenieros biomédicos certificados para mantenimiento preventivo y
              correctivo.
            </p>
          </div>
          <div class="val-card fade-in d2">
            <div class="val-icon"><i class="fas fa-globe-americas" aria-hidden="true"></i></div>
            <h3>Cobertura nacional</h3>
            <p>
              Presencia en los 32 departamentos de Colombia con logística especializada para equipos
              médicos.
            </p>
          </div>
          <div class="val-card fade-in d3">
            <div class="val-icon"><i class="fas fa-dollar-sign" aria-hidden="true"></i></div>
            <h3>Financiamiento</h3>
            <p>
              Planes de financiamiento para adquisición de equipos biomédicos, sujetos a evaluación
              y confirmación mediante propuesta formal.
            </p>
          </div>
          <div class="val-card fade-in d4">
            <div class="val-icon"><i class="fas fa-headset" aria-hidden="true"></i></div>
            <h3>Asesoría integral</h3>
            <p>
              Acompañamiento desde la evaluación de necesidades hasta la puesta en marcha del
              equipo.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ CATEGORIES ═══ -->
    <section class="section section-teal" aria-labelledby="cat-h2">
      <div class="container">
        <div class="s-header fade-in">
          <div class="s-label s-label-white">Catálogo por categoría</div>
          <h2 id="cat-h2" class="s-title s-title-white">Soluciones para cada área clínica</h2>
          <p class="s-sub s-sub-white">
            Equipos para UCI, quirófano, neonatología, cardiología, diagnóstico por imagen y más.
          </p>
        </div>
      </div>
      <div class="cat-grid" role="list">
        {
          categorias.map(c => (
            <a
              href={`/es/catalogo?cat=${c.slug}`}
              class="cat-card"
              role="listitem"
              aria-label={c.aria}
            >
              <div class="cat-card-bg" style={`background-image:url('${c.bg}')`} />
              <div class="cat-icon">
                <i class={`fas ${c.icon}`} aria-hidden="true" />
              </div>
              <div>
                <div class="cat-name">{c.nombre}</div>
                <div class="cat-count">{c.count}</div>
              </div>
              <div class="cat-arrow">
                <i class="fas fa-arrow-right" />
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <!-- ═══ IMG BAND ═══ -->
    <div class="img-band" aria-hidden="true">
      <img
        src="/assets/img/wr3d-equipo-multifuncional.webp"
        alt="Sala de diagnóstico con equipos radiológicos digitales I-ME Colombia"
        width="1920"
        height="320"
        loading="lazy"
      />
      <div class="img-band-overlay">
        <div class="img-band-text">
          <h3>Tecnología de diagnóstico por imagen</h3>
          <p>
            Sistemas de rayos X digitales, ecógrafos y equipos de radiología de última generación
            para su institución.
          </p>
        </div>
      </div>
    </div>

    <!-- ═══ FEATURED PRODUCTS ═══ -->
    <section class="section" id="productos" aria-labelledby="prod-h2">
      <div class="container">
        <div
          class="s-header fade-in"
          style="display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:16px"
        >
          <div>
            <div class="s-label">Equipos destacados</div>
            <h2 id="prod-h2" class="s-title">Nuestra selección principal</h2>
          </div>
          <a href="/es/catalogo" class="btn btn-outline"
            >Ver catálogo completo <i class="fas fa-arrow-right" style="font-size:11px"></i></a
          >
        </div>

        <div class="products-grid" role="list">
          {
            productosDestacados.map(p => (
              <article class="product-card fade-in" role="listitem">
                <a
                  class="product-img-wrap"
                  href={`/es/productos/${p.slug}`}
                  aria-label={`Ver ${p.nombre}`}
                >
                  <img
                    src={p.imagen_principal}
                    alt={p.nombre}
                    width="400"
                    height="280"
                    loading="lazy"
                  />
                  {p.familia_slug && <div class="product-cat-badge">{p.familia_slug}</div>}
                </a>
                <div class="product-body">
                  <h3 class="product-name">{p.nombre}</h3>
                  <p class="product-desc">{p.descripcion_corta}</p>
                  <div class="product-footer">
                    <a class="btn btn-primary btn-sm" href={`/es/productos/${p.slug}`}>
                      Ver detalles
                    </a>
                    <button
                      type="button"
                      class="btn btn-outline btn-sm"
                      data-add-cotizacion={p.slug}
                      data-nombre={p.nombre}
                      data-imagen={p.imagen_principal}
                    >
                      <i class="fab fa-whatsapp" /> Cotizar
                    </button>
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ═══ HOSPITAL ENVIRONMENT ═══ -->
    <section class="section section-off" aria-label="Ambientes hospitalarios equipados por I-ME">
      <div class="container">
        <div class="s-header s-header-center fade-in">
          <div class="s-label">Entorno clínico</div>
          <h2 class="s-title">Equipamos cada área de su institución</h2>
        </div>
        <div class="env-grid">
          <div class="env-card">
            <img
              src="/assets/img/equipamiento-biomedico-vanguardia.webp"
              alt="Equipamiento biomédico integral para instituciones de salud — I-ME Colombia"
              width="500"
              height="340"
              loading="lazy"
              decoding="async"
            />
            <div class="env-card-label">
              <span>Equipamiento Biomédico</span>
              <small>UCI · Diagnóstico · Quirófano</small>
            </div>
          </div>
          <div class="env-card" style="transition-delay:0.15s">
            <img
              src="/assets/img/sala-cirugia-robotica.webp"
              alt="Sala de cirugía robótica con equipos biomédicos avanzados — I-ME Colombia"
              width="500"
              height="340"
              loading="lazy"
              decoding="async"
            />
            <div class="env-card-label">
              <span>Sala de Cirugía Robótica</span>
              <small>Brazos robóticos · Monitores · Electrocirugía</small>
            </div>
          </div>
          <div class="env-card" style="transition-delay:0.3s">
            <img
              src="/assets/img/sala-radiologia-diagnostica.webp"
              alt="Sala de radiología y diagnóstico por imagen — equipos I-ME Colombia"
              width="500"
              height="340"
              loading="lazy"
              decoding="async"
            />
            <div class="env-card-label">
              <span>Radiología y Diagnóstico</span>
              <small>Ecógrafos · Rayos X · Monitores diagnósticos</small>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══ SERVICES ═══ -->
    <section class="section" id="servicios" aria-labelledby="svc-h2">
      <div class="container">
        <div
          class="s-header fade-in"
          style="display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:16px"
        >
          <div>
            <div class="s-label">Lo que hacemos</div>
            <h2 id="svc-h2" class="s-title">Servicios especializados</h2>
          </div>
          <a href="/es/servicios" class="btn btn-outline"
            >Ver todos los servicios <i class="fas fa-arrow-right" style="font-size:11px"></i></a
          >
        </div>

        <div class="services-list fade-in">
          {
            servicios.map(s => (
              <div class="svc-row">
                <div class="svc-num">{s.num}</div>
                <div>
                  <div class="svc-icon">
                    <i class={`fas ${s.icon}`} aria-hidden="true" />
                  </div>
                  <h3 class="svc-title">{s.titulo}</h3>
                  <p class="svc-desc">{s.desc}</p>
