---
/**
 * Landing estática de producto ES — getStaticPaths desde la capa de datos.
 */
import Layout from '../../../layouts/Layout.astro'
import ProductoLanding from '../../../components/ProductoLanding.astro'
import { t } from '../../../i18n/utils'
import {
  buildProductoSeo,
  buildCanonical,
  buildProductJsonLd,
  buildBreadcrumbJsonLd,
  combineJsonLd,
} from '../../../lib/seo'
import { getProductos, getFamilias, type Producto } from '../../../lib/datos'

const locale = 'es'

export async function getStaticPaths() {
  const productos = await getProductos({ pageSize: 1000 }, 'es')
  return productos.map((producto) => ({
    params: { slug: producto.slug },
    props: { producto },
  }))
}

interface Props {
  producto: Producto
}

const { producto } = Astro.props as Props

const familias = await getFamilias(locale)
const familia = familias.find((f) => f.slug === producto.familia_slug) ?? {
  id: producto.familia_slug,
  slug: producto.familia_slug,
  nombre: producto.familia_slug,
  descripcion: '',
  orden: 0,
  activo: true,
}

const todosProductos = await getProductos({ familia: producto.familia_slug, pageSize: 100 }, locale)
const relacionados = todosProductos.filter((p) => p.slug !== producto.slug).slice(0, 4)

const seo = buildProductoSeo(producto, locale)

const jsonLd = combineJsonLd(
  buildProductJsonLd(producto, locale, familia.nombre),
  buildBreadcrumbJsonLd([
    { name: t(locale, 'catalogo.migas_inicio'), url: buildCanonical('/es/') },
    { name: t(locale, 'catalogo.migas_catalogo'), url: buildCanonical('/es/catalogo') },
    { name: familia.nombre, url: buildCanonical(`/es/catalogo?familia=${familia.slug}`) },
    { name: producto.nombre, url: seo.canonical },
  ])
)
---

<Layout
  title={seo.title}
  description={seo.description}
  canonical={seo.canonical}
  locale={locale}
  currentPath={`/es/productos/${producto.slug}`}
  ogImage={seo.ogImage}
  jsonLd={jsonLd}
>
  <ProductoLanding
    producto={producto}
    familia={familia}
    relacionados={relacionados}
    locale={locale}
  />
</Layout>
