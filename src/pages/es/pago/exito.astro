---
/**
 * Página de resultado de pago — éxito. No indexable.
 * El estado real se verifica server-side vía consultar-pedido.
 */
import Layout from '../../../layouts/Layout.astro'
import ResultadoPago from '../../../components/ResultadoPago.astro'
import { buildPageTitle, buildCanonical } from '../../../lib/seo'

const locale = 'es'
const title = buildPageTitle('Pago confirmado')
const description = 'Confirmación de pago recibido.'
const canonical = buildCanonical('/es/pago/exito')
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  locale={locale}
  currentPath="/es/pago/exito"
  noindex
>
  <ResultadoPago locale={locale} tipo="exito" />
</Layout>
