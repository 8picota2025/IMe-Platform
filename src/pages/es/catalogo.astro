---
/**
 * Catálogo ES — explorador completo: familias, filtros, búsqueda,
 * facetas dinámicas, paginación y comparador (F2).
 */
import Layout from '../../layouts/Layout.astro'
import CatalogoExplorer from '../../components/CatalogoExplorer.astro'
import { t } from '../../i18n/utils'
import {
  buildCatalogoSeo,
  buildCanonical,
  buildOrganizationJsonLd,
  buildBreadcrumbJsonLd,
  combineJsonLd,
} from '../../lib/seo'
import { buildCatalogoIndex } from '../../lib/catalogo'

const locale = 'es'
const seo = buildCatalogoSeo(locale)
const items = await buildCatalogoIndex(locale)

const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: seo.title,
  itemListElement: items.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    url: buildCanonical(`/es/productos/${item.slug}`),
    name: item.nombre,
  })),
}

const jsonLd = combineJsonLd(
  buildOrganizationJsonLd(),
  buildBreadcrumbJsonLd([
    { name: t(locale, 'catalogo.migas_inicio'), url: buildCanonical('/es/') },
    { name: t(locale, 'catalogo.migas_catalogo'), url: seo.canonical },
  ]),
  itemListJsonLd
)
---

<Layout
  title={seo.title}
  description={seo.description}
  canonical={seo.canonical}
  locale={locale}
  currentPath="/es/catalogo"
  jsonLd={jsonLd}
>
  <div
    class="page-hero"
    style="padding-top:130px;padding-bottom:var(--space-md);background:var(--off)"
  >
    <div class="container">
      <span class="section-tag">{t(locale, 'catalogo.familias_titulo')}</span>
      <h1>{t(locale, 'catalogo.titulo')}</h1>
      <p style="color:var(--text-mid);max-width:560px;margin:0.75rem 0 0">
        24 equipos biomédicos en 8 categorías especializadas. Todos certificados INVIMA.
      </p>
    </div>
  </div>

  <div class="container">
    <CatalogoExplorer locale={locale} />
  </div>
</Layout>

<style>
  .section-tag {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--t900);
    background: var(--t100);
    padding: 0.3rem 0.875rem;
    border-radius: 999px;
    margin-block-end: 0.75rem;
  }
</style>
