---
import LegalPage from '../../../components/LegalPage.astro';
import { buildCanonical, buildPageTitle } from '../../../lib/seo';
import { legalEn } from '../../../data/legal-content';

const doc = legalEn.terms;
---

<LegalPage
  locale="en"
  currentPath="/en/legal/terms"
  title={buildPageTitle(doc.pageTitle)}
  description={doc.description}
  canonical={buildCanonical('/en/legal/terms')}
  badge={doc.badge}
  heading={doc.heading}
  summary={doc.summary}
  updatedAt={doc.updatedAt}
  sections={doc.sections}
  notice={doc.notice}
/>
