---
/**
 * Home EN — UI en inglés, contenido factual = COPY_CLIENTE_REVISAR.
 */
import Layout from '../../layouts/Layout.astro'
import { t } from '../../i18n/utils'
import { getFamilias, getProductosDestacados } from '../../lib/datos'
import { buildHomeSeo, buildOrganizationJsonLd } from '../../lib/seo'

const locale = 'en'
const seo = buildHomeSeo(locale)
const jsonLd = JSON.stringify(buildOrganizationJsonLd())

const familias = await getFamilias(locale)
const productosDestacados = await getProductosDestacados(locale)

const metricas = [
  { valor: '24+', label: 'Equipment categories' },
  { valor: '100%', label: 'INVIMA certified' },
  { valor: '32 Dpt', label: 'National coverage' },
]
---

<Layout
  title={seo.title}
  description={seo.description}
  canonical={seo.canonical}
  locale={locale}
  currentPath="/en/"
  ogImage={seo.ogImage}
  jsonLd={jsonLd}
>
  <!-- HERO -->
  <section class="hero" aria-label="Main header">
    <div class="hero__bg" aria-hidden="true">
      <video
        class="hero__video"
        src="/assets/extraccion/video/quirofano-completo.mp4"
        autoplay
        muted
        loop
        playsinline
        preload="none"
        poster="/assets/extraccion/img/Img11.jpg"
        aria-hidden="true"></video>
      <div class="hero__overlay"></div>
    </div>
    <div class="hero__ecg" aria-hidden="true">
      <svg viewBox="0 0 800 60" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <polyline
          points="0,30 100,30 130,30 145,10 160,50 175,5 190,55 205,30 220,30 350,30 380,30 395,10 410,50 425,5 440,55 455,30 470,30 600,30 630,30 645,10 660,50 675,5 690,55 705,30 720,30 800,30"
          fill="none"
          stroke="rgba(126,217,87,0.35)"
          stroke-width="1.5"></polyline>
      </svg>
    </div>
    <div class="hero__content container">
      <div class="hero__text" data-animate="hero-text">
        <span class="badge badge-teal hero__badge">I-ME International Medical Enterprise</span>
        <h1 class="hero__title">COPY_CLIENTE_REVISAR — Biomedical equipment that saves lives</h1>
        <p class="hero__subtitle">
          COPY_CLIENTE_REVISAR — We distribute internationally certified world-class medical
          technology for hospitals, clinics and health centers throughout Colombia.
        </p>
        <div class="hero__ctas">
          <a href="/en/catalog" class="btn btn-primary hero__cta-primary"
            >{t(locale, 'hero.ver_catalogo')}</a
          >
          <a href="/en/contact" class="btn btn-ghost">{t(locale, 'hero.solicitar_asesoria')}</a>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST BAND -->
  <section class="trust-band section-sm" aria-label="Trust metrics">
    <div class="container">
      <ul class="trust-band__list" role="list">
        {
          metricas.map((m) => (
            <li class="trust-band__item" data-animate="fade-up">
              <strong class="trust-band__valor">{m.valor}</strong>
              <span class="trust-band__label">{m.label}</span>
            </li>
          ))
        }
        <li class="trust-band__item trust-band__item--sello" data-animate="fade-up">
          <span class="trust-band__sello-icon" aria-hidden="true">✓</span>
          <span class="trust-band__label">CE · FDA · INVIMA</span>
        </li>
      </ul>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="about section" id="about" aria-labelledby="about-heading">
    <div class="container about__grid">
      <div class="about__image" data-animate="fade-left">
        <img
          src="/assets/extraccion/img/Img11.jpg"
          alt="ICU multiparameter monitor"
          width="600"
          height="450"
          loading="lazy"
          decoding="async"
          class="about__img"
        />
      </div>
      <div class="about__content" data-animate="fade-right">
        <span class="section-tag">{t(locale, 'quienes_somos.titulo')}</span>
        <h2 id="about-heading">
          COPY_CLIENTE_REVISAR — Medical technology that transforms healthcare institutions
        </h2>
        <p>
          COPY_CLIENTE_REVISAR — I-ME International Medical Enterprise is a Colombian company with
          more than 15 years of experience in the distribution, installation and maintenance of
          high-tech biomedical equipment for the healthcare sector.
        </p>
        <div class="about__pillars">
          <div class="pillar"><h3 class="pillar__title">Vision</h3><p>COPY_CLIENTE_REVISAR</p></div>
          <div class="pillar">
            <h3 class="pillar__title">Mission</h3><p>COPY_CLIENTE_REVISAR</p>
          </div>
          <div class="pillar">
            <h3 class="pillar__title">Quality</h3><p>COPY_CLIENTE_REVISAR</p>
          </div>
          <div class="pillar">
            <h3 class="pillar__title">Commitment</h3><p>COPY_CLIENTE_REVISAR</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CATEGORIES -->
  <section
    class="categorias section"
    id="categories"
    aria-labelledby="categorias-heading"
    style="background:var(--off)"
  >
    <div class="container">
      <div class="section-header" data-animate="fade-up">
        <span class="section-tag">{t(locale, 'catalogo.familias_titulo')}</span>
        <h2 id="categorias-heading">COPY_CLIENTE_REVISAR — Solutions for every specialty</h2>
      </div>
      <ul class="categorias__grid" role="list">
        {
          familias.map((familia) => (
            <li data-animate="fade-up">
              <a href={`/en/catalog?cat=${familia.slug}`} class="categoria-card">
                <div class="categoria-card__icon" aria-hidden="true">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="28"
                    height="28"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M22 12h-4l-3 9L9 3l-3 9H2" />
                  </svg>
                </div>
                <h3 class="categoria-card__name">{familia.nombre}</h3>
                <p class="categoria-card__desc">{familia.descripcion}</p>
                <span class="categoria-card__link" aria-hidden="true">
                  {t(locale, 'catalogo.ver_categoria')} →
                </span>
              </a>
            </li>
          ))
        }
      </ul>
      <div class="section-cta" data-animate="fade-up">
        <a href="/en/catalog" class="btn btn-primary">{t(locale, 'destacados.ver_todos')}</a>
      </div>
    </div>
  </section>

  <!-- FEATURED PRODUCTS -->
  <section class="destacados section" id="featured" aria-labelledby="destacados-heading">
    <div class="container">
      <div class="section-header" data-animate="fade-up">
        <span class="section-tag">{t(locale, 'destacados.titulo')}</span>
        <h2 id="destacados-heading">{t(locale, 'destacados.titulo')}</h2>
      </div>
      <ul class="destacados__grid" role="list">
        {
          productosDestacados.map((producto) => (
            <li class="card producto-card" data-animate="fade-up">
              <a
                href={`/en/products/${producto.slug}`}
                class="producto-card__link"
                aria-label={`View details for ${producto.nombre}`}
              >
                <div class="producto-card__img-wrapper">
                  <img
                    src={producto.imagen_principal}
                    alt={producto.nombre}
                    width="400"
                    height="280"
                    loading="lazy"
                    decoding="async"
                    class="producto-card__img"
                  />
                </div>
                <div class="producto-card__body">
                  <p class="producto-card__familia">{producto.familia_slug}</p>
                  <h3 class="producto-card__nombre">{producto.nombre}</h3>
                  <p class="producto-card__desc">{producto.descripcion_corta}</p>
                  <span class="btn btn-secondary producto-card__cta">
                    {t(locale, 'catalogo.ver_detalle')}
                  </span>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
      <div class="section-cta" data-animate="fade-up">
        <a href="/en/catalog" class="btn btn-primary">{t(locale, 'destacados.ver_todos')}</a>
      </div>
    </div>
  </section>

  <!-- CLOSING CTA -->
  <section class="cierre section" aria-label="Final call to action" style="background:var(--t900)">
    <div class="container cierre__inner" data-animate="fade-up">
      <h2 class="cierre__title">COPY_CLIENTE_REVISAR — Ready to equip your institution?</h2>
      <p class="cierre__subtitle">COPY_CLIENTE_REVISAR — "We equip your mission to save lives."</p>
      <div class="cierre__ctas">
        <a href="/en/contact" class="btn btn-primary cierre__btn-primary"
          >{t(locale, 'nav.cta_cotizar')}</a
        >
        <a
          href="https://wa.me/573138674059"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-ghost">WhatsApp <span class="sr-only">(opens in new window)</span></a
        >
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding-top: 70px;
  }
  .hero__bg {
    position: absolute;
    inset: 0;
  }
  .hero__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(11, 27, 34, 0.82) 0%,
      rgba(15, 76, 92, 0.6) 60%,
      rgba(11, 27, 34, 0.55) 100%
    );
  }
  .hero__ecg {
    position: absolute;
    bottom: 15%;
    left: 0;
    right: 0;
    pointer-events: none;
    opacity: 0.6;
  }
  .hero__ecg svg {
    width: 100%;
    height: 60px;
  }
  .hero__content {
    position: relative;
    z-index: 1;
    padding-block: var(--space-3xl);
  }
  .hero__text {
    max-width: 680px;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .hero__badge {
    align-self: flex-start;
    background: rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(8px);
  }
  .hero__title {
    font-size: var(--step-5);
    font-weight: 800;
    color: white;
    line-height: 1.08;
    margin: 0;
  }
  .hero__subtitle {
    font-size: var(--step-1);
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.6;
    margin: 0;
    max-width: 560px;
  }
  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .hero__cta-primary {
    background: white;
    color: var(--t900);
  }
  .hero__cta-primary:hover {
    background: var(--off);
    color: var(--t800);
  }
  .trust-band {
    background: var(--t900);
    color: white;
  }
  .trust-band__list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
    text-align: center;
  }
  .trust-band__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
  }
  .trust-band__valor {
    font-family: var(--font-display);
    font-size: var(--step-3);
    font-weight: 800;
    color: white;
  }
  .trust-band__label {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.7);
  }
  .trust-band__item--sello .trust-band__sello-icon {
    font-size: var(--step-2);
    color: var(--green);
    font-weight: 800;
  }
  .section-tag {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--t900);
    background: var(--t100);
    padding: 0.3rem 0.875rem;
    border-radius: 999px;
    margin-block-end: 0.75rem;
  }
  .section-header {
    text-align: center;
    max-width: 680px;
    margin-inline: auto;
    margin-block-end: var(--space-xl);
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .section-cta {
    text-align: center;
    margin-block-start: var(--space-xl);
  }
  .about__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: center;
  }
  @media (min-width: 900px) {
    .about__grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  .about__img {
    border-radius: var(--radius-lg);
    width: 100%;
    height: auto;
    object-fit: cover;
    box-shadow: var(--shadow-lg);
  }
  .about__content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .about__content h2 {
    margin: 0;
  }
  .about__content p {
    color: var(--text-mid);
    margin: 0;
  }
  .about__pillars {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-block-start: 0.5rem;
  }
  .pillar {
    background: var(--off);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    border: 1px solid var(--border);
  }
  .pillar__title {
    font-size: 0.85rem;
    font-weight: 700;
    font-family: var(--font-display);
    color: var(--t900);
    margin: 0 0 0.35rem;
  }
  .pillar p {
    font-size: 0.825rem;
    color: var(--text-mid);
    margin: 0;
  }
  .categorias__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .categoria-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.5rem;
    background: var(--white);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    text-decoration: none;
    color: var(--text);
    transition:
      box-shadow 260ms var(--ease),
      transform 260ms var(--ease),
      border-color 260ms var(--ease);
  }
  .categoria-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
    border-color: var(--t700);
  }
  .categoria-card__icon {
    width: 48px;
    height: 48px;
    border-radius: var(--radius);
    background: var(--t100);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--t900);
  }
  .categoria-card__name {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    color: var(--ink);
    margin: 0;
  }
  .categoria-card__desc {
    font-size: 0.825rem;
    color: var(--text-mid);
    line-height: 1.5;
    margin: 0;
    flex: 1;
  }
  .categoria-card__link {
    font-size: 0.8rem;
    font-weight: 600;
    font-family: var(--font-display);
    color: var(--t800);
    margin-block-start: auto;
  }
  .destacados__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .producto-card {
    display: flex;
    flex-direction: column;
  }
  .producto-card__link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .producto-card__img-wrapper {
    overflow: hidden;
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    aspect-ratio: 4/3;
    background: var(--off2);
  }
  .producto-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms var(--ease);
  }
  .producto-card:hover .producto-card__img {
    transform: scale(1.04);
  }
  .producto-card__body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }
  .producto-card__familia {
    font-size: 0.7rem;
    font-weight: 700;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--t800);
    margin: 0;
  }
  .producto-card__nombre {
    font-size: 1rem;
    font-weight: 700;
    color: var(--ink);
    margin: 0;
    line-height: 1.3;
  }
  .producto-card__desc {
    font-size: 0.825rem;
    color: var(--text-mid);
    line-height: 1.5;
    margin: 0;
    flex: 1;
  }
  .producto-card__cta {
    align-self: flex-start;
    margin-block-start: 0.75rem;
    font-size: 0.8rem;
  }
  .cierre__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.5rem;
  }
  .cierre__title {
    font-size: var(--step-3);
    font-weight: 800;
    color: white;
    margin: 0;
  }
  .cierre__subtitle {
    font-size: var(--step-1);
    color: rgba(255, 255, 255, 0.75);
    max-width: 600px;
    margin: 0;
  }
  .cierre__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }
  .cierre__btn-primary {
    background: white;
    color: var(--t900);
  }
  .cierre__btn-primary:hover {
    background: var(--off);
    color: var(--t800);
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>

<script>
  import { prefersReducedMotion } from '../../lib/motion'
  if (!prefersReducedMotion()) {
    const load = async () => {
      const { gsap } = await import('gsap')
      const { ScrollTrigger } = await import('gsap/ScrollTrigger')
      gsap.registerPlugin(ScrollTrigger)
      document.querySelectorAll('[data-animate]').forEach((el) => {
        const type = el.getAttribute('data-animate')
        const vars: gsap.TweenVars = { opacity: 0 }
        const toVars: gsap.TweenVars = {
          opacity: 1,
          duration: 0.7,
          ease: 'power3.out',
          scrollTrigger: { trigger: el, start: 'top 88%', once: true },
        }
        if (type === 'fade-up' || type === 'hero-text') {
          vars.y = 30
          toVars.y = 0
        } else if (type === 'fade-left') {
          vars.x = -30
          toVars.x = 0
        } else if (type === 'fade-right') {
          vars.x = 30
          toVars.x = 0
        }
        gsap.fromTo(el, vars, toVars)
      })
    }
    load()
  }
</script>
