---
/**
 * Payment result page — pending verification. Not indexable.
 * The real status is verified server-side via consultar-pedido.
 */
import Layout from '../../../layouts/Layout.astro'
import ResultadoPago from '../../../components/ResultadoPago.astro'
import { buildPageTitle, buildCanonical } from '../../../lib/seo'

const locale = 'en'
const title = buildPageTitle('Payment in progress')
const description = 'Your payment is being verified.'
const canonical = buildCanonical('/en/payment/pending')
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  locale={locale}
  currentPath="/en/payment/pending"
  noindex
>
  <ResultadoPago locale={locale} tipo="pendiente" />
</Layout>
