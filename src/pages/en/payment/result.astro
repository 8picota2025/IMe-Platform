---
/**
 * Neutral Wompi callback page. It does not assume success or failure:
 * the real status is verified server-side via consultar-pedido.
 */
import Layout from '../../../layouts/Layout.astro';
import ResultadoPago from '../../../components/ResultadoPago.astro';
import { buildPageTitle, buildCanonical } from '../../../lib/seo';

const locale = 'en';
const title = buildPageTitle('Payment result');
const description = 'Verification of the real payment status.';
const canonical = buildCanonical('/en/payment/result');
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  locale={locale}
  currentPath="/en/payment/result"
  noindex
>
  <ResultadoPago locale={locale} tipo="resultado" />
</Layout>
