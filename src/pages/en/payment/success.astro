---
/**
 * Payment result page — success. Not indexable.
 * The real status is verified server-side via consultar-pedido.
 */
import Layout from '../../../layouts/Layout.astro'
import ResultadoPago from '../../../components/ResultadoPago.astro'
import { buildPageTitle, buildCanonical } from '../../../lib/seo'

const locale = 'en'
const title = buildPageTitle('Payment confirmed')
const description = 'Payment confirmation.'
const canonical = buildCanonical('/en/payment/success')
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  locale={locale}
  currentPath="/en/payment/success"
  noindex
>
  <ResultadoPago locale={locale} tipo="exito" />
</Layout>
