---
/**
 * Knowledge EN — visual stub (BACKLOG_V2: content/articles hub).
 * No invented articles or resources — "coming soon" notice only.
 */
import Layout from '../../layouts/Layout.astro'
import { buildPageTitle, buildCanonical } from '../../lib/seo'
import { t } from '../../i18n/utils'

const locale = 'en'
const title = buildPageTitle(t(locale, 'conocimiento.titulo'))
const description = t(locale, 'conocimiento.descripcion')
const canonical = buildCanonical('/en/knowledge')
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  locale={locale}
  currentPath="/en/knowledge"
>
  <div
    class="page-hero conocimiento-hero"
    style="padding-top:130px;padding-bottom:var(--space-2xl);background:var(--off)"
  >
    <div class="container">
      <span class="section-tag">{t(locale, 'conocimiento.proximamente')}</span>
      <h1>{t(locale, 'conocimiento.titulo')}</h1>
      <p style="color:var(--text-mid);max-width:560px;margin:0.75rem 0 0">
        {t(locale, 'conocimiento.descripcion')}
      </p>
      <a href="/en/contact" class="btn btn-secondary" style="margin-top:1.5rem">
        {t(locale, 'conocimiento.cta_contacto')}
      </a>
    </div>
  </div>
</Layout>

<style>
  .section-tag {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--t900);
    background: var(--t100);
    padding: 0.3rem 0.875rem;
    border-radius: 999px;
    margin-block-end: 0.75rem;
  }
  .conocimiento-hero {
    min-height: 60vh;
    display: flex;
    align-items: center;
  }
</style>
