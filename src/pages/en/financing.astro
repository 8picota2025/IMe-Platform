---
/**
 * Financing EN — stub; real rates/terms pending BLOQUEANTE_LEGAL (see es/financiacion.astro)
 */
import Layout from '../../layouts/Layout.astro'
import { buildPageTitle, buildCanonical } from '../../lib/seo'

const locale = 'en'
const title = buildPageTitle('Financing — Medical Equipment Acquisition Plans')
const description =
  'Flexible acquisition plans for biomedical equipment for healthcare institutions.'
const canonical = buildCanonical('/en/financing')
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  locale={locale}
  currentPath="/en/financing"
>
  <div style="padding-top:130px;padding-bottom:var(--space-2xl);background:var(--off)">
    <div class="container">
      <h1>Financing</h1>
      <p style="color:var(--text-mid)">
        Financing terms and rates pending final approval. BLOQUEANTE_LEGAL.
      </p>
    </div>
  </div>
  <section class="section container">
    <a href="/en/contact" class="btn btn-primary">Contact an Advisor</a>
  </section>
</Layout>
