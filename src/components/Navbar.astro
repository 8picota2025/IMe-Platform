---
/**
 * Navbar — Logo real, links, selector idioma, CTA, tema, carrito placeholder, menú mobile.
 */
import type { Locale } from '../i18n/utils'
import { t, getLocalizedPath } from '../i18n/utils'

interface Props {
  locale: Locale
  currentPath: string
}

const { locale, currentPath } = Astro.props

const links = [
  { key: 'nav.inicio', href: getLocalizedPath('/', locale) },
  { key: 'nav.catalogo', href: getLocalizedPath('/catalogo', locale) },
  { key: 'nav.servicios', href: getLocalizedPath('/servicios', locale) },
  { key: 'nav.financiacion', href: getLocalizedPath('/financiacion', locale) },
  { key: 'nav.contacto', href: getLocalizedPath('/contacto', locale) },
]

const altLocale: Locale = locale === 'es' ? 'en' : 'es'
const altHref = getLocalizedPath(currentPath, altLocale)
---

<header class="navbar" id="navbar" role="banner">
  <div class="navbar__inner container">
    <!-- Logo -->
    <a
      href={getLocalizedPath('/', locale)}
      class="navbar__logo"
      aria-label={t(locale, 'accesibilidad.logo')}
    >
      <img
        src="/assets/extraccion/img/logo-ime.png"
        alt="I-ME International Medical Enterprise"
        width="120"
        height="40"
        loading="eager"
        decoding="async"
      />
    </a>

    <!-- Navigation desktop -->
    <nav
      class="navbar__nav"
      aria-label={locale === 'es' ? 'Navegación principal' : 'Main navigation'}
    >
      <ul class="navbar__list" role="list">
        {
          links.map(({ key, href }) => (
            <li>
              <a
                href={href}
                class:list={[
                  'navbar__link',
                  {
                    'navbar__link--active':
                      currentPath === href || currentPath.startsWith(href + '/'),
                  },
                ]}
                aria-current={currentPath === href ? 'page' : undefined}
              >
                {t(locale, key)}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Right actions -->
    <div class="navbar__actions">
      <!-- Selector de idioma -->
      <a
        href={altHref}
        class="navbar__lang-btn"
        aria-label={`${t(locale, 'nav.cambiar_idioma')} (${altLocale.toUpperCase()})`}
        lang={altLocale}
      >
        {altLocale.toUpperCase()}
      </a>

      <!-- Toggle tema -->
      <button
        id="theme-toggle"
        class="navbar__icon-btn"
        aria-label={t(locale, 'nav.tema_oscuro')}
        type="button"
      >
        <svg
          class="icon-sun"
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line
            x1="12"
            y1="21"
            x2="12"
            y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line
            x1="18.36"
            y1="18.36"
            x2="19.78"
            y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line
            x1="21"
            y1="12"
            x2="23"
            y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line
            x1="18.36"
            y1="5.64"
            x2="19.78"
            y2="4.22"></line>
        </svg>
        <svg
          class="icon-moon"
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>

      <!-- Lista de cotización (equipos) -->
      <button
        id="nav-cotizacion-btn"
        class="navbar__icon-btn navbar__cart-btn"
        aria-label={t(locale, 'nav.cotizacion')}
        type="button"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline
            points="14 2 14 8 20 8"></polyline><line x1="9" y1="13" x2="15" y2="13"></line><line
            x1="9"
            y1="17"
            x2="15"
            y2="17"></line>
        </svg>
        <span
          id="nav-cotizacion-badge"
          class="navbar__cart-badge"
          aria-live="polite"
          aria-atomic="true"
          style="display:none">0</span
        >
        <span class="sr-only" data-cotizacion-suffix>{t(locale, 'nav.items_cotizacion')}</span>
      </button>

      <!-- Carrito de consumibles -->
      <button
        id="nav-carrito-btn"
        class="navbar__icon-btn navbar__cart-btn"
        aria-label={t(locale, 'nav.carrito')}
        type="button"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path
            d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
        </svg>
        <span
          id="nav-carrito-badge"
          class="navbar__cart-badge"
          aria-live="polite"
          aria-atomic="true"
          style="display:none">0</span
        >
        <span class="sr-only" data-carrito-suffix>{t(locale, 'nav.items_carrito')}</span>
      </button>

      <!-- CTA -->
      <a href={getLocalizedPath('/contacto', locale)} class="btn btn-primary navbar__cta">
        {t(locale, 'nav.cta_cotizar')}
      </a>

      <!-- Hamburger mobile -->
      <button
        id="menu-toggle"
        class="navbar__hamburger"
        aria-label={t(locale, 'nav.abrir_menu')}
        aria-expanded="false"
        aria-controls="mobile-menu"
        type="button"
      >
        <span class="hamburger-bar"></span>
        <span class="hamburger-bar"></span>
        <span class="hamburger-bar"></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="navbar__mobile"
    role="dialog"
    aria-modal="true"
    aria-label={locale === 'es' ? 'Menú de navegación' : 'Navigation menu'}
    hidden
  >
    <nav aria-label={locale === 'es' ? 'Navegación móvil' : 'Mobile navigation'}>
      <ul class="navbar__mobile-list" role="list">
        {
          links.map(({ key, href }) => (
            <li>
              <a
                href={href}
                class:list={[
                  'navbar__mobile-link',
                  { 'navbar__mobile-link--active': currentPath === href },
                ]}
                aria-current={currentPath === href ? 'page' : undefined}
              >
                {t(locale, key)}
              </a>
            </li>
          ))
        }
        <li>
          <a href={altHref} class="navbar__mobile-link" lang={altLocale}>
            {t(locale, 'nav.cambiar_idioma')}: {altLocale.toUpperCase()}
          </a>
        </li>
        <li>
          <a
            href={getLocalizedPath('/contacto', locale)}
            class="btn btn-primary"
            style="width:100%;justify-content:center;margin-top:1rem"
          >
            {t(locale, 'nav.cta_cotizar')}
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    transition: box-shadow 260ms var(--ease);
  }
  [data-theme='dark'] .navbar {
    background: rgba(11, 27, 34, 0.95);
  }
  .navbar.scrolled {
    box-shadow: var(--shadow-md);
  }
  .navbar__inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    height: 70px;
  }
  .navbar__logo {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }
  .navbar__logo img {
    height: 38px;
    width: auto;
  }
  .navbar__nav {
    flex: 1;
    display: none;
  }
  @media (min-width: 1024px) {
    .navbar__nav {
      display: block;
    }
  }
  .navbar__list {
    display: flex;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .navbar__link {
    display: block;
    padding: 0.5rem 0.875rem;
    border-radius: 8px;
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-mid);
    text-decoration: none;
    transition:
      color 180ms var(--ease),
      background-color 180ms var(--ease);
  }
  .navbar__link:hover,
  .navbar__link--active {
    color: var(--t900);
    background: var(--t50);
  }
  .navbar__actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-left: auto;
  }
  .navbar__lang-btn {
    padding: 0.4rem 0.65rem;
    border-radius: 8px;
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--text-mid);
    text-decoration: none;
    border: 1px solid var(--border-mid);
    letter-spacing: 0.05em;
    transition:
      background-color 180ms var(--ease),
      color 180ms var(--ease);
  }
  .navbar__lang-btn:hover {
    background: var(--t50);
    color: var(--t900);
  }
  .navbar__icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-mid);
    cursor: pointer;
    position: relative;
    transition:
      background-color 180ms var(--ease),
      color 180ms var(--ease);
  }
  .navbar__icon-btn:hover {
    background: var(--t50);
    color: var(--t900);
  }
  .navbar__icon-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .navbar__cart-badge {
    position: absolute;
    top: -4px;
    right: -4px;
    background: var(--t900);
    color: white;
    font-size: 0.65rem;
    font-weight: 700;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
  .icon-moon {
    display: none;
  }
  [data-theme='dark'] .icon-sun {
    display: none;
  }
  [data-theme='dark'] .icon-moon {
    display: block;
  }

  .navbar__cta {
    display: none;
    font-size: 0.875rem;
    padding: 0.6rem 1.25rem;
  }
  @media (min-width: 640px) {
    .navbar__cta {
      display: inline-flex;
    }
  }
  .navbar__hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 38px;
    height: 38px;
    border: 1px solid var(--border);
    background: transparent;
    border-radius: 8px;
    cursor: pointer;
    padding: 0 9px;
  }
  @media (min-width: 1024px) {
    .navbar__hamburger {
      display: none;
    }
  }
  .hamburger-bar {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition:
      transform 260ms var(--ease),
      opacity 260ms var(--ease);
  }
  .navbar__hamburger[aria-expanded='true'] .hamburger-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .navbar__hamburger[aria-expanded='true'] .hamburger-bar:nth-child(2) {
    opacity: 0;
  }
  .navbar__hamburger[aria-expanded='true'] .hamburger-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Mobile menu */
  .navbar__mobile {
    position: fixed;
    top: 70px;
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--white);
    padding: 1.5rem;
    overflow-y: auto;
    z-index: 99;
  }
  .navbar__mobile[hidden] {
    display: none;
  }
  .navbar__mobile-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .navbar__mobile-link {
    display: block;
    padding: 1rem;
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text);
    text-decoration: none;
    border-bottom: 1px solid var(--border);
    transition: color 180ms var(--ease);
  }
  .navbar__mobile-link:hover,
  .navbar__mobile-link--active {
    color: var(--t900);
  }
</style>

<script>
  // Navbar scroll shadow
  const navbar = document.getElementById('navbar')
  if (navbar) {
    window.addEventListener(
      'scroll',
      () => {
        navbar.classList.toggle('scrolled', window.scrollY > 10)
      },
      { passive: true }
    )
  }

  // Theme toggle
  const themeBtn = document.getElementById('theme-toggle')
  if (themeBtn) {
    themeBtn.addEventListener('click', () => {
      const isDark = document.documentElement.getAttribute('data-theme') === 'dark'
      const next = isDark ? 'light' : 'dark'
      document.documentElement.setAttribute('data-theme', next)
      try {
        localStorage.setItem('ime-theme', next)
      } catch {
        /* ignore */
      }
      themeBtn.setAttribute(
        'aria-label',
        next === 'dark' ? 'Cambiar a tema claro' : 'Cambiar a tema oscuro'
      )
    })
  }

  // Mobile menu with focus trap
  const menuToggle = document.getElementById('menu-toggle')
  const mobileMenu = document.getElementById('mobile-menu')

  function openMenu() {
    if (!mobileMenu || !menuToggle) return
    mobileMenu.removeAttribute('hidden')
    menuToggle.setAttribute('aria-expanded', 'true')
    menuToggle.setAttribute('aria-label', menuToggle.dataset['closeLabel'] ?? 'Cerrar menú')
    document.body.style.overflow = 'hidden'
    // Focus first link
    const firstLink = mobileMenu.querySelector<HTMLElement>('a, button')
    firstLink?.focus()
  }

  function closeMenu() {
    if (!mobileMenu || !menuToggle) return
    mobileMenu.setAttribute('hidden', '')
    menuToggle.setAttribute('aria-expanded', 'false')
    menuToggle.setAttribute('aria-label', menuToggle.dataset['openLabel'] ?? 'Abrir menú')
    document.body.style.overflow = ''
    menuToggle.focus()
  }

  if (menuToggle) {
    menuToggle.dataset['openLabel'] = menuToggle.getAttribute('aria-label') ?? 'Abrir menú'
    menuToggle.dataset['closeLabel'] = 'Cerrar menú de navegación'
    menuToggle.addEventListener('click', () => {
      const isOpen = menuToggle.getAttribute('aria-expanded') === 'true'
      if (isOpen) {
        closeMenu()
      } else {
        openMenu()
      }
    })
  }

  // Escape key closes menu
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menuToggle?.getAttribute('aria-expanded') === 'true') {
      closeMenu()
    }
  })

  // Focus trap inside mobile menu
  if (mobileMenu) {
    mobileMenu.addEventListener('keydown', (e) => {
      if (e.key !== 'Tab') return
      const focusable = Array.from(
        mobileMenu.querySelectorAll<HTMLElement>('a, button, [tabindex]:not([tabindex="-1"])')
      )
      const first = focusable[0]
      const last = focusable[focusable.length - 1]
      if (!first || !last) return
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault()
        last.focus()
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault()
        first.focus()
      }
    })
  }

  // Close menu on link click
  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu)
  })

  // Carrito de consumibles
  void (async () => {
    const { getCarritoCantidad, suscribirCarrito, abrirCarrito } = await import('../lib/carrito')
    const carritoBtn = document.getElementById('nav-carrito-btn')
    const carritoBadge = document.getElementById('nav-carrito-badge')

    function renderCarritoBadge(cantidad: number) {
      if (!carritoBadge) return
      carritoBadge.textContent = String(cantidad)
      carritoBadge.style.display = cantidad > 0 ? 'flex' : 'none'
    }

    renderCarritoBadge(getCarritoCantidad())
    suscribirCarrito((items) => {
      const total = items.reduce((sum, item) => sum + item.cantidad, 0)
      renderCarritoBadge(total)
    })
    carritoBtn?.addEventListener('click', () => abrirCarrito())
  })()

  // Lista de cotización de equipos
  void (async () => {
    const { getCotizacionCantidad, suscribirCotizacion, abrirCotizacion } =
      await import('../lib/cotizacion-equipos')
    const cotizacionBtn = document.getElementById('nav-cotizacion-btn')
    const cotizacionBadge = document.getElementById('nav-cotizacion-badge')

    function renderCotizacionBadge(cantidad: number) {
      if (!cotizacionBadge) return
      cotizacionBadge.textContent = String(cantidad)
      cotizacionBadge.style.display = cantidad > 0 ? 'flex' : 'none'
    }

    renderCotizacionBadge(getCotizacionCantidad())
    suscribirCotizacion((items) => {
      const total = items.reduce((sum, item) => sum + item.cantidad, 0)
      renderCotizacionBadge(total)
    })
    cotizacionBtn?.addEventListener('click', () => abrirCotizacion())
  })()
</script>
