---
/**
 * Asesor comercial RAG — widget de chat.
 * Lógica real: Edge Function `asesor` (Fase Asesor), vía src/lib/asesor.ts.
 * Regla: solo asesoría comercial — prohibido diagnóstico clínico o precio comprometido.
 */
import type { Locale } from '../i18n/utils';
import { t } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const turnstileSiteKey = (import.meta.env['PUBLIC_TURNSTILE_SITE_KEY'] as string | undefined) ?? '';

const asesorConfig = {
  locale,
  turnstileSiteKey,
  whatsappUrl: 'https://wa.me/573138674059',
  contactoHref: locale === 'en' ? '/en/contact' : '/es/contacto',
  i18n: {
    bienvenida: t(locale, 'asesor.bienvenida'),
    buscando: t(locale, 'asesor.buscando'),
    limite: t(locale, 'asesor.limite'),
    degradado: t(locale, 'asesor.degradado'),
    error: t(locale, 'asesor.error'),
    noDisponible: t(locale, 'asesor.no_disponible'),
    verProducto: t(locale, 'asesor.ver_producto'),
    handoffWhatsapp: t(locale, 'asesor.handoff_whatsapp'),
    handoffCotizacion: t(locale, 'asesor.handoff_cotizacion'),
    reintentar: t(locale, 'asesor.reintentar'),
    nuevaVentana: t(locale, 'accesibilidad.nueva_ventana'),
  },
};
---

<!-- Botón flotante para abrir el asesor -->
<button
  id="asesor-trigger"
  class="asesor-fab"
  aria-label={t(locale, 'asesor.abrir')}
  aria-haspopup="dialog"
  aria-expanded="false"
  aria-controls="asesor-dialog"
  type="button"
  transition:persist={`asesor-fab-${locale}`}
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="24"
    height="24"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
  </svg>
  <span class="asesor-fab__label">{locale === 'es' ? 'Asesor' : 'Advisor'}</span>
</button>

<!-- Dialog del asesor -->
<div
  id="asesor-dialog"
  class="asesor-dialog"
  role="dialog"
  aria-modal="true"
  aria-label={t(locale, 'asesor.titulo')}
  data-asesor-config={JSON.stringify(asesorConfig)}
  hidden
  transition:persist={`asesor-dialog-${locale}`}
>
  <div class="asesor-dialog__inner">
    <!-- Header -->
    <div class="asesor-dialog__header">
      <div class="asesor-dialog__title-row">
        <div class="asesor-dialog__avatar" aria-hidden="true">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"
            ></circle>
          </svg>
        </div>
        <div>
          <p class="asesor-dialog__name">{t(locale, 'asesor.titulo')}</p>
          <p class="asesor-dialog__status">
            <span class="asesor-dialog__dot" aria-hidden="true"></span>
            {locale === 'es' ? 'En línea' : 'Online'}
          </p>
        </div>
      </div>
      <button
        id="asesor-close"
        class="asesor-dialog__close"
        aria-label={t(locale, 'asesor.cerrar')}
        type="button"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <!-- Mensajes -->
    <div
      id="asesor-messages"
      class="asesor-dialog__messages"
      role="log"
      aria-live="polite"
      aria-label={locale === 'es' ? 'Conversación con el asesor' : 'Conversation with advisor'}
    >
      <!-- Los mensajes se insertan dinámicamente -->
    </div>

    <!-- Contenedor invisible para el widget Turnstile -->
    <div id="asesor-turnstile" class="asesor-turnstile" aria-hidden="true"></div>

    <!-- Input -->
    <form id="asesor-form" class="asesor-dialog__form" novalidate>
      <label for="asesor-input" class="sr-only">{t(locale, 'asesor.placeholder')}</label>
      <textarea
        id="asesor-input"
        name="mensaje"
        class="asesor-dialog__input"
        placeholder={t(locale, 'asesor.placeholder')}
        rows={2}
        maxlength={500}
        autocomplete="off"></textarea>
      <button
        type="submit"
        class="asesor-dialog__send btn btn-primary"
        aria-label={t(locale, 'asesor.enviar')}
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"
          ></polygon>
        </svg>
      </button>
    </form>
  </div>
</div>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
  .asesor-fab {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 200;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    background: var(--t900);
    color: white;
    border: none;
    border-radius: 999px;
    font-family: var(--font-display);
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    box-shadow: var(--shadow-lg);
    transition:
      transform 180ms var(--ease),
      background-color 180ms var(--ease);
  }
  .asesor-fab:hover {
    background: var(--t800);
    transform: scale(1.04);
  }
  .asesor-fab__label {
    display: none;
  }
  @media (min-width: 480px) {
    .asesor-fab__label {
      display: inline;
    }
  }

  .asesor-dialog {
    position: fixed;
    bottom: 5rem;
    right: 1.5rem;
    z-index: 201;
    width: min(380px, calc(100vw - 2rem));
    max-height: calc(100vh - 8rem);
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-lg);
    background: var(--white);
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--border);
    overflow: hidden;
  }
  .asesor-dialog[hidden] {
    display: none;
  }
  .asesor-dialog__inner {
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .asesor-dialog__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    background: var(--t900);
    color: white;
    gap: 1rem;
  }
  .asesor-dialog__title-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .asesor-dialog__avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .asesor-dialog__name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    margin: 0;
    color: white;
  }
  .asesor-dialog__status {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
  }
  .asesor-dialog__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--green);
    display: inline-block;
  }
  .asesor-dialog__close {
    background: transparent;
    border: none;
    color: rgba(255, 255, 255, 0.7);
    cursor: pointer;
    padding: 0.25rem;
    border-radius: 4px;
    transition: color 180ms var(--ease);
    flex-shrink: 0;
  }
  .asesor-dialog__close:hover {
    color: white;
  }

  .asesor-dialog__messages {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-height: 180px;
    max-height: 300px;
  }
  .asesor-turnstile {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
  .asesor-dialog__form {
    display: flex;
    gap: 0.5rem;
    padding: 0.75rem;
    border-top: 1px solid var(--border);
  }
  .asesor-dialog__input {
    flex: 1;
    border: 1px solid var(--border-mid);
    border-radius: var(--radius);
    padding: 0.6rem 0.875rem;
    font-family: var(--font-body);
    font-size: 0.875rem;
    resize: none;
    color: var(--text);
    background: var(--white);
    transition: border-color 180ms var(--ease);
  }
  .asesor-dialog__input:focus {
    outline: none;
    border-color: var(--t800);
  }
  .asesor-dialog__input:disabled {
    opacity: 0.6;
  }
  .asesor-dialog__send {
    padding: 0.6rem 0.875rem;
    flex-shrink: 0;
  }
  .asesor-dialog__send:disabled {
    opacity: 0.6;
    cursor: default;
  }

  /* Burbujas de chat */
  .chat-bubble {
    max-width: 85%;
    padding: 0.65rem 0.875rem;
    border-radius: 12px;
    font-size: 0.875rem;
    line-height: 1.5;
    overflow-wrap: anywhere;
  }
  .chat-bubble--user {
    background: var(--t900);
    color: white;
    align-self: flex-end;
    border-bottom-right-radius: 4px;
  }
  .chat-bubble--asesor {
    background: var(--off2);
    color: var(--text);
    align-self: flex-start;
    border-bottom-left-radius: 4px;
  }
  .chat-bubble--loading {
    background: var(--off2);
    color: var(--text-muted);
    align-self: flex-start;
    border-bottom-left-radius: 4px;
  }
  .chat-bubble p {
    margin: 0 0 0.5rem;
  }
  .chat-bubble p:last-child {
    margin-bottom: 0;
  }
  .asesor-bubble--rich p {
    margin: 0;
  }

  /* Tarjetas de producto sugeridas */
  .asesor-productos {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }
  .asesor-producto {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--white);
    text-decoration: none;
    color: var(--text);
    transition: border-color 180ms var(--ease);
    min-width: 0;
  }
  .asesor-producto:hover {
    border-color: var(--t800);
  }
  .asesor-producto__img {
    width: 40px;
    height: 40px;
    border-radius: 6px;
    object-fit: cover;
    flex-shrink: 0;
    background: var(--off);
  }
  .asesor-producto__nombre {
    flex: 1;
    min-width: 0;
    font-size: 0.8rem;
    font-weight: 600;
    line-height: 1.3;
    overflow-wrap: anywhere;
  }
  .asesor-producto__link {
    font-size: 0.7rem;
    color: var(--text-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* CTA de handoff (WhatsApp / cotización / reintentar) */
  .asesor-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.5rem;
    padding: 0.5rem 0.875rem;
    border-radius: var(--radius);
    background: var(--t900);
    color: white;
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background-color 180ms var(--ease);
  }
  .asesor-cta:hover {
    background: var(--t800);
  }

  @media (max-width: 479px) {
    .asesor-dialog {
      right: 0.75rem;
      bottom: 4.75rem;
      width: min(420px, calc(100vw - 1.5rem));
      max-height: min(620px, calc(100vh - 7rem));
    }

    .asesor-dialog__header {
      padding: 0.875rem 1rem;
    }

    .asesor-dialog__messages {
      max-height: min(380px, calc(100vh - 14rem));
      padding: 0.875rem;
    }

    .chat-bubble {
      max-width: 100%;
    }

    .asesor-producto {
      align-items: flex-start;
      flex-wrap: wrap;
    }

    .asesor-producto__img {
      width: 36px;
      height: 36px;
    }

    .asesor-producto__link {
      width: 100%;
      padding-left: 46px;
      white-space: normal;
    }
  }
</style>

<script>
  import { resetTransientUiState } from '../lib/motion';
  import type {
    MensajeAsesor,
    RespuestaAsesor,
    AccionHandoff,
    ErrorAsesor,
    ProductoSugerido,
  } from '../lib/asesor';

  interface AsesorI18n {
    bienvenida: string;
    buscando: string;
    limite: string;
    degradado: string;
    error: string;
    noDisponible: string;
    verProducto: string;
    handoffWhatsapp: string;
    handoffCotizacion: string;
    reintentar: string;
    nuevaVentana: string;
  }

  interface AsesorConfig {
    locale: 'es' | 'en';
    turnstileSiteKey: string;
    whatsappUrl: string;
    contactoHref: string;
    i18n: AsesorI18n;
  }

  declare global {
    interface Window {
      turnstile?: {
        render: (container: string | HTMLElement, options: Record<string, unknown>) => string;
        execute: (widgetId: string | HTMLElement, options?: Record<string, unknown>) => void;
        reset: (widgetId?: string | HTMLElement) => void;
      };
    }
  }

  // Persistent state across navigations
  let asesorLib: {
    preguntarAsesor: (params: {
      mensaje: string;
      historial: { rol: 'usuario' | 'asesor'; contenido: string; timestamp: Date }[];
      locale: 'es' | 'en';
      turnstileToken?: string | undefined;
    }) => Promise<
      | {
          ok: true;
          respuesta: {
            texto: string;
            productos: Array<{
              slug: string;
              nombre: string;
              imagen: string | null;
              urlLanding: string;
              score: number;
            }>;
            accionHandoff: { tipo: 'whatsapp' | 'cotizacion'; resumen: string } | null;
            modo: 'rag' | 'keyword_degradado' | 'sin_resultados';
          };
        }
      | {
          ok: false;
          error:
            | { tipo: 'rate_limited'; retryAfterSegundos: number | null }
            | { tipo: 'no_disponible' }
            | { tipo: 'error' };
        }
    >;
    resetHistorial: () => void;
    obtenerHistorial: () => { rol: 'usuario' | 'asesor'; contenido: string; timestamp: Date }[];
  } | null = null;
  let enviando = false;
  let ultimoMensaje: string | null = null;
  let turnstileWidgetId: string | null = null;
  let turnstileLoadPromise: Promise<void> | null = null;
  let resolveTurnstileToken: ((token: string | undefined) => void) | null = null;
  const historial: MensajeAsesor[] = [];

  // Per-init cleanup
  let asesorEscHandler: ((e: KeyboardEvent) => void) | null = null;
  const _imeInit = new WeakSet<Element>();

  function initAsesor() {
    const trigger = document.getElementById('asesor-trigger');
    const dialog = document.getElementById('asesor-dialog');
    if (!trigger || !dialog) return;

    // transition:persist keeps the same DOM element across navigations — skip re-binding
    if (_imeInit.has(trigger)) return;
    _imeInit.add(trigger);

    // Fresh element only: clean up any stale doc-level handler and reset turnstile
    if (asesorEscHandler) {
      document.removeEventListener('keydown', asesorEscHandler);
      asesorEscHandler = null;
    }
    turnstileWidgetId = null;
    resolveTurnstileToken = null;

    const closeBtn = document.getElementById('asesor-close');
    const form = document.getElementById('asesor-form') as HTMLFormElement | null;
    const messagesEl = document.getElementById('asesor-messages');
    const inputEl = document.getElementById('asesor-input') as HTMLTextAreaElement | null;
    const sendBtn = form?.querySelector<HTMLButtonElement>('.asesor-dialog__send') ?? null;
    const turnstileContainer = document.getElementById('asesor-turnstile');

    const config: AsesorConfig = JSON.parse(dialog.dataset.asesorConfig ?? '{}') as AsesorConfig;
    let localInitialized = false;

    function escapeHtml(value: string): string {
      return value
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function renderMessageHtml(value: string): string {
      const escaped = escapeHtml(value.trim());
      if (!escaped) return '';
      return escaped
        .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
        .split(/\n{2,}/)
        .map(block => `<p>${block.replace(/\n/g, '<br>')}</p>`)
        .join('');
    }

    function addBubble(text: string, role: 'user' | 'asesor' | 'loading'): HTMLElement | undefined {
      if (!messagesEl) return;
      const div = document.createElement('div');
      div.className = `chat-bubble chat-bubble--${role}`;
      if (role === 'asesor') {
        div.innerHTML = renderMessageHtml(text);
      } else {
        div.textContent = text;
      }
      messagesEl.appendChild(div);
      messagesEl.scrollTop = messagesEl.scrollHeight;
      return div;
    }

    function addHtmlBubble(html: string): HTMLElement | undefined {
      if (!messagesEl) return;
      const div = document.createElement('div');
      div.className = 'chat-bubble chat-bubble--asesor asesor-bubble--rich';
      div.innerHTML = html;
      messagesEl.appendChild(div);
      messagesEl.scrollTop = messagesEl.scrollHeight;
      return div;
    }

    function buildProductosHtml(productos: ProductoSugerido[]): string {
      const items = productos
        .map(p => {
          const imagen = p.imagen
            ? `<img class="asesor-producto__img" src="${escapeHtml(p.imagen)}" alt="" loading="lazy" width="40" height="40" />`
            : '';
          return `<a class="asesor-producto" href="${escapeHtml(p.urlLanding)}">${imagen}<span class="asesor-producto__nombre">${escapeHtml(p.nombre)}</span><span class="asesor-producto__link">${escapeHtml(config.i18n.verProducto)}</span></a>`;
        })
        .join('');
      return `<div class="asesor-productos">${items}</div>`;
    }

    function buildHandoffHtml(handoff: AccionHandoff): string {
      if (handoff.tipo === 'whatsapp') {
        const url = handoff.resumen
          ? `${config.whatsappUrl}?text=${encodeURIComponent(handoff.resumen)}`
          : config.whatsappUrl;
        return `<a class="asesor-cta" href="${escapeHtml(url)}" target="_blank" rel="noopener noreferrer">${escapeHtml(config.i18n.handoffWhatsapp)} <span class="sr-only">${escapeHtml(config.i18n.nuevaVentana)}</span></a>`;
      }
      return `<a class="asesor-cta" href="${escapeHtml(config.contactoHref)}">${escapeHtml(config.i18n.handoffCotizacion)}</a>`;
    }

    function renderRespuesta(respuesta: RespuestaAsesor) {
      addBubble(respuesta.texto, 'asesor');
      if (respuesta.modo === 'keyword_degradado' && respuesta.productos.length > 0) {
        addBubble(config.i18n.degradado, 'loading');
      }
      if (respuesta.productos.length > 0) addHtmlBubble(buildProductosHtml(respuesta.productos));
      if (respuesta.accionHandoff) addHtmlBubble(buildHandoffHtml(respuesta.accionHandoff));
    }

    function renderError(error: ErrorAsesor) {
      if (error.tipo === 'rate_limited') {
        addBubble(config.i18n.limite, 'asesor');
        return;
      }
      if (error.tipo === 'no_disponible') {
        addHtmlBubble(
          `<p>${escapeHtml(config.i18n.noDisponible)}</p>${buildHandoffHtml({ tipo: 'whatsapp', resumen: '' })}`
        );
        return;
      }
      addHtmlBubble(
        `<p>${escapeHtml(config.i18n.error)}</p><button type="button" class="asesor-cta asesor-cta--retry" data-asesor-retry>${escapeHtml(config.i18n.reintentar)}</button>`
      );
    }

    function setEnviando(value: boolean) {
      enviando = value;
      if (inputEl) inputEl.disabled = value;
      if (sendBtn) sendBtn.disabled = value;
      form?.setAttribute('aria-busy', value ? 'true' : 'false');
    }

    function loadTurnstileScript(): Promise<void> {
      if (window.turnstile) return Promise.resolve();
      if (turnstileLoadPromise) return turnstileLoadPromise;
      turnstileLoadPromise = new Promise((resolve, reject) => {
        const script = document.createElement('script');
        script.src = 'https://challenges.cloudflare.com/turnstile/v0/api.js';
        script.async = true;
        script.onload = () => resolve();
        script.onerror = () => reject(new Error('turnstile load error'));
        document.head.appendChild(script);
      });
      return turnstileLoadPromise;
    }

    async function getTurnstileToken(): Promise<string | undefined> {
      if (!config.turnstileSiteKey || !turnstileContainer) return undefined;
      try {
        await loadTurnstileScript();
        if (!window.turnstile) return undefined;

        if (turnstileWidgetId === null) {
          turnstileWidgetId = window.turnstile.render(turnstileContainer, {
            sitekey: config.turnstileSiteKey,
            size: 'normal',
            appearance: 'execute',
            execution: 'execute',
            callback: (token: string) => resolveTurnstileToken?.(token),
            'error-callback': () => resolveTurnstileToken?.(undefined),
            'expired-callback': () => resolveTurnstileToken?.(undefined),
          });
        }
        const widgetId = turnstileWidgetId;
        if (widgetId === null) return undefined;

        return await new Promise<string | undefined>(resolve => {
          const timeout = setTimeout(() => resolve(undefined), 8000);
          resolveTurnstileToken = token => {
            clearTimeout(timeout);
            resolveTurnstileToken = null;
            resolve(token);
          };
          window.turnstile?.reset(widgetId);
          window.turnstile?.execute(widgetId);
        });
      } catch {
        return undefined;
      }
    }

    async function enviarMensaje(mensaje: string) {
      if (enviando) return;
      ultimoMensaje = mensaje;
      setEnviando(true);
      const loadingBubble = addBubble(config.i18n.buscando, 'loading');

      if (!asesorLib) asesorLib = await import('../lib/asesor');
      const turnstileToken = await getTurnstileToken();

      const resultado = await asesorLib.preguntarAsesor({
        mensaje,
        historial,
        locale: config.locale,
        turnstileToken,
      });

      loadingBubble?.remove();
      setEnviando(false);

      if (!resultado.ok) {
        renderError(resultado.error);
        return;
      }

      historial.push({ rol: 'usuario', contenido: mensaje, timestamp: new Date() });
      historial.push({
        rol: 'asesor',
        contenido: resultado.respuesta.texto,
        timestamp: new Date(),
      });
      renderRespuesta(resultado.respuesta);
    }

    function openDialog() {
      if (!dialog || !trigger) return;
      resetTransientUiState();
      dialog.removeAttribute('hidden');
      trigger.setAttribute('aria-expanded', 'true');

      if (!localInitialized) {
        localInitialized = true;
        addBubble(config.i18n.bienvenida, 'asesor');
      }

      setTimeout(() => inputEl?.focus(), 100);
    }

    function closeDialog() {
      if (!dialog || !trigger) return;
      dialog.setAttribute('hidden', '');
      trigger.setAttribute('aria-expanded', 'false');
      trigger.focus();
    }

    trigger.addEventListener('click', openDialog);
    closeBtn?.addEventListener('click', closeDialog);

    asesorEscHandler = (e: KeyboardEvent) => {
      if (e.key === 'Escape' && !dialog.hasAttribute('hidden')) closeDialog();
    };
    document.addEventListener('keydown', asesorEscHandler);

    dialog.addEventListener('keydown', e => {
      if (e.key !== 'Tab') return;
      const focusable = Array.from(
        dialog.querySelectorAll<HTMLElement>(
          'button, textarea, a[href], [tabindex]:not([tabindex="-1"])'
        )
      );
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (!first || !last) return;
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    });

    form?.addEventListener('submit', async e => {
      e.preventDefault();
      const msg = inputEl?.value.trim();
      if (!msg) return;

      addBubble(msg, 'user');
      if (inputEl) inputEl.value = '';

      await enviarMensaje(msg);
    });

    messagesEl?.addEventListener('click', e => {
      const target = e.target as HTMLElement;
      if (target.closest('[data-asesor-retry]') && ultimoMensaje) {
        target.closest('.chat-bubble')?.remove();
        void enviarMensaje(ultimoMensaje);
      }
    });

    inputEl?.addEventListener('keydown', e => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        form?.requestSubmit();
      }
    });
  }

  document.addEventListener('astro:page-load', initAsesor);
  initAsesor();
</script>
