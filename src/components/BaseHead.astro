---
/**
 * BaseHead — metadatos SEO, hreflang, OG, JSON-LD.
 * Solo datos reales. Ver lib/seo.ts.
 */
import { getAlternateLinks } from '../i18n/utils';
import type { Locale } from '../i18n/utils';
import '../styles/globals.css';

interface Props {
  title: string;
  description: string;
  canonical: string;
  locale: Locale;
  ogImage?: string;
  jsonLd?: string;
  currentPath: string;
  noindex?: boolean;
  fontAwesome?: boolean;
}

const {
  title,
  description,
  canonical,
  locale,
  ogImage,
  jsonLd,
  currentPath,
  noindex,
  fontAwesome,
} = Astro.props;
const alternates = getAlternateLinks(currentPath);
const ogImageUrl = ogImage ?? 'https://i-me.com.co/assets/img/logo-ime.png';
const ogImageType = ogImageUrl.endsWith('.svg')
  ? 'image/svg+xml'
  : ogImageUrl.endsWith('.png')
    ? 'image/png'
    : 'image/jpeg';
const robotsContent = noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large';
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<!-- Primary Meta -->
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<meta name="robots" content={robotsContent} />

<!-- hreflang -->
{alternates.map(alt => <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />)}

<!-- Font Awesome 6.5.1 — iconos fieles al sitio en producción (solo páginas que lo solicitan) -->
{
  fontAwesome && (
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
  )
}

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonical} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:type" content={ogImageType} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={title} />
<meta property="og:locale" content={locale === 'en' ? 'en_US' : 'es_CO'} />
<meta property="og:locale:alternate" content={locale === 'en' ? 'es_CO' : 'en_US'} />
<meta property="og:site_name" content="I-ME International Medical Enterprise" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />
<meta name="twitter:image:alt" content={title} />

<!-- Theme color -->
<meta name="theme-color" content="#0F4C5C" />
<meta name="theme-color" media="(prefers-color-scheme: dark)" content="#0b1b22" />

<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="manifest" href="/manifest.json" />

<!-- JSON-LD -->
{jsonLd && <script is:inline type="application/ld+json" set:html={jsonLd} />}

<!-- Anti-FOUC: detecta tema guardado antes de pintar -->
<script is:inline>
  (function () {
    try {
      const t = localStorage.getItem('ime-theme');
      if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
    } catch {
      // ignore localStorage errors
    }
  })();
</script>
