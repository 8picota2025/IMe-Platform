<script>
  import { initCatalogo } from '../lib/catalogo-cliente';

  const locale = document.documentElement.lang === 'en' ? 'en' : 'es';
  const catalogoWindow = window as Window & { __imeCatalogoCleanup?: (() => void) | null };

  catalogoWindow.__imeCatalogoCleanup?.();

  // Captura el deep-link de categoría (?cat=slug) antes de inicializar el
  // catálogo, ya que initCatalogo puede limpiar la query de la URL.
  const cat = new URLSearchParams(window.location.search).get('cat');

  catalogoWindow.__imeCatalogoCleanup = initCatalogo(locale);

  // Replica el comportamiento de las cat-card de producción: abre el catálogo
  // ya filtrado por familia activando el botón de filtro correspondiente.
  if (cat) {
    requestAnimationFrame(() => {
      const btn = document.querySelector<HTMLButtonElement>(
        `[data-familia-filter="${CSS.escape(cat)}"]`
      );
      if (btn) btn.click();
    });
  }
</script>
