---
/**
 * Lista de cotización de equipos — drawer lateral accesible (rol dialog,
 * focus trap, Escape, aria-live). Estado en src/lib/cotizacion-equipos.ts
 * (sessionStorage). Envío real vía submitCotizacion (src/lib/datos.ts).
 */
import type { Locale } from '../i18n/utils';
import { t } from '../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const privacidadHref = locale === 'en' ? '/en/legal/privacy' : '/es/legal/privacidad';

const config = {
  locale,
  i18n: {
    titulo: t(locale, 'cotizacion_equipos.titulo'),
    cerrar: t(locale, 'cotizacion_equipos.cerrar'),
    vacio: t(locale, 'cotizacion_equipos.vacio'),
    vacioCta: t(locale, 'cotizacion_equipos.vacio_cta'),
    eliminar: t(locale, 'cotizacion_equipos.eliminar'),
    vaciar: t(locale, 'cotizacion_equipos.vaciar'),
    cantidad: t(locale, 'cotizacion_equipos.cantidad'),
    aumentar: t(locale, 'carrito.aumentar'),
    disminuir: t(locale, 'carrito.disminuir'),
    formTitulo: t(locale, 'cotizacion_equipos.form_titulo'),
    nombre: t(locale, 'cotizacion_equipos.nombre'),
    apellido: t(locale, 'cotizacion_equipos.apellido'),
    email: t(locale, 'cotizacion_equipos.email'),
    telefono: t(locale, 'cotizacion_equipos.telefono'),
    institucion: t(locale, 'cotizacion_equipos.institucion'),
    mensaje: t(locale, 'cotizacion_equipos.mensaje'),
    enviar: t(locale, 'cotizacion_equipos.enviar'),
    enviando: t(locale, 'cotizacion_equipos.enviando'),
    exito: t(locale, 'cotizacion_equipos.exito'),
    error: t(locale, 'cotizacion_equipos.error'),
    consentimiento: t(locale, 'cotizacion_equipos.consentimiento'),
    productosTitulo: t(locale, 'cotizacion_equipos.productos_titulo'),
    requerido: t(locale, 'cotizacion_equipos.requerido'),
  },
  catalogoHref: locale === 'en' ? '/en/catalog' : '/es/catalogo',
};
---

<div
  id="cotizacion-backdrop"
  class="drawer-backdrop"
  hidden
  transition:persist={`cotizacion-backdrop-${locale}`}
>
</div>

<aside
  id="cotizacion-drawer"
  class="cotizacion-drawer"
  role="dialog"
  aria-modal="true"
  aria-label={config.i18n.titulo}
  transition:persist={`cotizacion-drawer-${locale}`}
  data-cotizacion-config={JSON.stringify(config)}
  hidden
>
  <div class="cotizacion-drawer__header">
    <h2 class="cotizacion-drawer__title">{config.i18n.titulo}</h2>
    <button
      id="cotizacion-close"
      class="cotizacion-drawer__close"
      aria-label={config.i18n.cerrar}
      type="button"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>

  <div class="cotizacion-drawer__body">
    <p id="cotizacion-vacio" class="cotizacion-vacio">
      {config.i18n.vacio}
      <a href={config.catalogoHref} class="btn btn-secondary">{config.i18n.vacioCta}</a>
    </p>

    <h3 id="cotizacion-productos-titulo" class="cotizacion-subtitulo" hidden>
      {config.i18n.productosTitulo}
    </h3>
    <ul id="cotizacion-items" class="cotizacion-items" aria-live="polite" aria-atomic="false"></ul>

    <button
      id="cotizacion-vaciar"
      class="btn btn-secondary cotizacion-vaciar-btn"
      type="button"
      hidden
    >
      {config.i18n.vaciar}
    </button>

    <form id="cotizacion-form" class="cotizacion-form" novalidate hidden>
      <h3>{config.i18n.formTitulo}</h3>
      <div class="cotizacion-grid">
        <div class="cotizacion-field">
          <label for="cotizacion-nombre">{config.i18n.nombre}</label>
          <input
            id="cotizacion-nombre"
            name="nombre"
            type="text"
            required
            autocomplete="given-name"
          />
        </div>
        <div class="cotizacion-field">
          <label for="cotizacion-apellido">{config.i18n.apellido}</label>
          <input
            id="cotizacion-apellido"
            name="apellido"
            type="text"
            required
            autocomplete="family-name"
          />
        </div>
      </div>
      <div class="cotizacion-field">
        <label for="cotizacion-email">{config.i18n.email}</label>
        <input id="cotizacion-email" name="email" type="email" required autocomplete="email" />
      </div>
      <div class="cotizacion-field">
        <label for="cotizacion-telefono">{config.i18n.telefono}</label>
        <input id="cotizacion-telefono" name="telefono" type="tel" required autocomplete="tel" />
      </div>
      <div class="cotizacion-field">
        <label for="cotizacion-institucion">{config.i18n.institucion}</label>
        <input
          id="cotizacion-institucion"
          name="institucion"
          type="text"
          autocomplete="organization"
        />
      </div>
      <div class="cotizacion-field">
        <label for="cotizacion-mensaje">{config.i18n.mensaje}</label>
        <textarea id="cotizacion-mensaje" name="mensaje" rows={3}></textarea>
      </div>
      <label class="cotizacion-checkbox">
        <input id="cotizacion-consentimiento" name="consentimiento" type="checkbox" required />
        <span>
          {config.i18n.consentimiento}
          <a href={privacidadHref} target="_blank" rel="noopener noreferrer">
            {t(locale, 'footer.privacidad')}
          </a>
        </span>
      </label>

      <p
        id="cotizacion-mensaje-estado"
        class="cotizacion-estado"
        role="status"
        aria-live="polite"
        hidden
      >
      </p>

      <button id="cotizacion-submit" class="btn btn-primary" type="submit"
        >{config.i18n.enviar}</button
      >
    </form>
  </div>
</aside>

<style>
  .drawer-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(11, 27, 34, 0.45);
    z-index: 210;
  }
  .drawer-backdrop[hidden] {
    display: none;
  }

  .cotizacion-drawer {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    z-index: 211;
    width: min(420px, 100vw);
    display: flex;
    flex-direction: column;
    background: var(--white);
    box-shadow: var(--shadow-lg);
    transform: translateX(100%);
  }
  .cotizacion-drawer[hidden] {
    display: none;
  }

  .cotizacion-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 1.5rem;
    background: var(--t900);
    color: white;
  }
  .cotizacion-drawer__title {
    margin: 0;
    font-size: 1.1rem;
  }
  .cotizacion-drawer__close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    border: none;
    background: rgba(255, 255, 255, 0.12);
    color: white;
    cursor: pointer;
  }
  .cotizacion-drawer__close:hover {
    background: rgba(255, 255, 255, 0.22);
  }

  .cotizacion-drawer__body {
    flex: 1;
    overflow-y: auto;
    padding: 1.25rem 1.5rem;
  }
  .cotizacion-vacio {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
    color: var(--text-mid);
    font-size: 0.9rem;
  }
  .cotizacion-vacio[hidden] {
    display: none;
  }
  .cotizacion-subtitulo {
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-mid);
    margin: 0 0 0.75rem;
  }
  .cotizacion-subtitulo[hidden] {
    display: none;
  }

  .cotizacion-items {
    list-style: none;
    margin: 0 0 1rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .cotizacion-item {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.75rem;
    align-items: start;
    padding-block-end: 0.75rem;
    border-bottom: 1px solid var(--border);
  }
  .cotizacion-item__nombre {
    font-weight: 600;
    color: var(--ink);
    font-size: 0.875rem;
    margin: 0 0 0.4rem;
  }
  .cotizacion-item__qty {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .cotizacion-item__qty button {
    width: 26px;
    height: 26px;
    border-radius: 6px;
    border: 1px solid var(--border-mid);
    background: transparent;
    cursor: pointer;
    font-size: 1rem;
    line-height: 1;
  }
  .cotizacion-item__qty button:hover {
    background: var(--t50);
  }
  .cotizacion-item__qty span {
    min-width: 1.5rem;
    text-align: center;
    font-size: 0.875rem;
  }
  .cotizacion-item__remove {
    border: none;
    background: transparent;
    color: var(--text-mid);
    cursor: pointer;
    padding: 0.25rem;
  }
  .cotizacion-item__remove:hover {
    color: var(--t900);
  }

  .cotizacion-vaciar-btn {
    width: 100%;
    justify-content: center;
    font-size: 0.85rem;
    margin-bottom: 1.5rem;
  }
  .cotizacion-vaciar-btn[hidden] {
    display: none;
  }

  .cotizacion-form {
    border-top: 1px solid var(--border);
    padding-top: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .cotizacion-form[hidden] {
    display: none;
  }
  .cotizacion-form h3 {
    font-size: 0.95rem;
    margin: 0 0 0.25rem;
  }
  .cotizacion-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }
  .cotizacion-field {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .cotizacion-field label {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-mid);
  }
  .cotizacion-field input,
  .cotizacion-field textarea {
    padding: 0.55rem 0.7rem;
    border: 1px solid var(--border-mid);
    border-radius: 8px;
    font-size: 0.875rem;
    background: var(--white);
    color: var(--ink);
    font-family: inherit;
    resize: vertical;
  }
  .cotizacion-field input:focus-visible,
  .cotizacion-field textarea:focus-visible {
    outline: 2px solid var(--t800);
    outline-offset: 1px;
  }
  .cotizacion-checkbox {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--text-mid);
    cursor: pointer;
  }
  .cotizacion-checkbox input {
    margin-top: 0.2rem;
  }
  .cotizacion-estado {
    border-radius: 8px;
    padding: 0.6rem 0.8rem;
    font-size: 0.8rem;
  }
  .cotizacion-estado[hidden] {
    display: none;
  }
  .cotizacion-estado--exito {
    background: #e6f4ea;
    border: 1px solid #a8d5b5;
    color: #1e4620;
  }
  .cotizacion-estado--error {
    background: #fdecea;
    border: 1px solid #f5b5ad;
    color: #8a1f11;
  }

  @media (prefers-reduced-motion: reduce) {
    .cotizacion-drawer {
      transition: none;
    }
  }
</style>

<script>
  import {
    getCotizacionItems,
    actualizarCantidadCotizacion,
    quitarDeCotizacion,
    vaciarCotizacion,
    suscribirCotizacion,
    alAbrirCotizacion,
    type CotizacionItem,
  } from '../lib/cotizacion-equipos';
  import { submitCotizacion } from '../lib/datos';
  import { abrirDrawer, cerrarDrawer, resetTransientUiState } from '../lib/motion';

  interface CotizacionI18n {
    titulo: string;
    cerrar: string;
    vacio: string;
    vacioCta: string;
    eliminar: string;
    vaciar: string;
    cantidad: string;
    aumentar: string;
    disminuir: string;
    formTitulo: string;
    nombre: string;
    apellido: string;
    email: string;
    telefono: string;
    institucion: string;
    mensaje: string;
    enviar: string;
    enviando: string;
    exito: string;
    error: string;
    consentimiento: string;
    productosTitulo: string;
    requerido: string;
  }

  interface CotizacionConfig {
    locale: 'es' | 'en';
    i18n: CotizacionI18n;
    catalogoHref: string;
  }

  let unsubCambioCotizacion: (() => void) | null = null;
  let unsubAbrirCotizacion: (() => void) | null = null;
  let cotizacionAbortController: AbortController | null = null;

  function initCotizacionDrawer() {
    const drawer = document.getElementById('cotizacion-drawer');
    if (!drawer) return;

    cotizacionAbortController?.abort();
    cotizacionAbortController = new AbortController();
    const { signal } = cotizacionAbortController;

    unsubCambioCotizacion?.();
    unsubCambioCotizacion = null;
    unsubAbrirCotizacion?.();
    unsubAbrirCotizacion = null;

    const backdrop = document.getElementById('cotizacion-backdrop');
    const closeBtn = document.getElementById('cotizacion-close');
    const itemsEl = document.getElementById('cotizacion-items');
    const vacioEl = document.getElementById('cotizacion-vacio');
    const productosTituloEl = document.getElementById('cotizacion-productos-titulo');
    const vaciarBtn = document.getElementById('cotizacion-vaciar') as HTMLButtonElement | null;
    const formEl = document.getElementById('cotizacion-form') as HTMLFormElement | null;
    const submitBtn = document.getElementById('cotizacion-submit') as HTMLButtonElement | null;
    const estadoEl = document.getElementById('cotizacion-mensaje-estado');

    const config: CotizacionConfig = JSON.parse(
      drawer.dataset.cotizacionConfig ?? '{}'
    ) as CotizacionConfig;
    const { i18n } = config;
    let enviando = false;

    function escapeHtml(value: string): string {
      return value
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function render(items: CotizacionItem[]) {
      if (!itemsEl || !vacioEl || !formEl || !vaciarBtn || !productosTituloEl) return;
      if (items.length === 0) {
        vacioEl.hidden = false;
        productosTituloEl.hidden = true;
        itemsEl.innerHTML = '';
        vaciarBtn.hidden = true;
        formEl.hidden = true;
        return;
      }
      vacioEl.hidden = true;
      productosTituloEl.hidden = false;
      vaciarBtn.hidden = false;
      formEl.hidden = false;

      itemsEl.innerHTML = items
        .map(
          item => `
            <li class="cotizacion-item" data-slug="${escapeHtml(item.slug)}">
              <div>
                <p class="cotizacion-item__nombre">${escapeHtml(item.nombre)}</p>
                <div class="cotizacion-item__qty">
                  <button type="button" data-action="dec" aria-label="${escapeHtml(i18n.disminuir)}">−</button>
                  <span aria-label="${escapeHtml(i18n.cantidad)}">${item.cantidad}</span>
                  <button type="button" data-action="inc" aria-label="${escapeHtml(i18n.aumentar)}">+</button>
                </div>
              </div>
              <button type="button" class="cotizacion-item__remove" data-action="remove" aria-label="${escapeHtml(i18n.eliminar)}: ${escapeHtml(item.nombre)}">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
              </button>
            </li>`
        )
        .join('');
    }

    render(getCotizacionItems());
    unsubCambioCotizacion = suscribirCotizacion(render);

    itemsEl?.addEventListener(
      'click',
      event => {
        const target = event.target as HTMLElement;
        const button = target.closest<HTMLElement>('button[data-action]');
        if (!button) return;
        const li = button.closest<HTMLElement>('.cotizacion-item');
        const slug = li?.dataset.slug;
        if (!slug) return;
        const items = getCotizacionItems();
        const item = items.find(i => i.slug === slug);
        if (!item) return;
        const action = button.dataset.action;
        if (action === 'inc') actualizarCantidadCotizacion(slug, item.cantidad + 1);
        else if (action === 'dec') actualizarCantidadCotizacion(slug, item.cantidad - 1);
        else if (action === 'remove') quitarDeCotizacion(slug);
      },
      { signal }
    );

    vaciarBtn?.addEventListener(
      'click',
      () => {
        vaciarCotizacion();
      },
      { signal }
    );

    function open() {
      if (!drawer || !backdrop) return;
      resetTransientUiState();
      drawer.removeAttribute('hidden');
      backdrop.removeAttribute('hidden');
      document.body.style.overflow = 'hidden';
      void abrirDrawer(drawer, backdrop);
      const firstFocusable = drawer.querySelector<HTMLElement>(
        'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
      );
      firstFocusable?.focus();
    }

    function close() {
      if (!drawer || !backdrop) return;
      void cerrarDrawer(drawer, backdrop, () => {
        drawer.setAttribute('hidden', '');
        backdrop.setAttribute('hidden', '');
        document.body.style.overflow = '';
      });
    }

    unsubAbrirCotizacion = alAbrirCotizacion(open);
    closeBtn?.addEventListener('click', close, { signal });
    backdrop?.addEventListener('click', close, { signal });

    document.addEventListener(
      'keydown',
      (event: KeyboardEvent) => {
        if (event.key === 'Escape' && !drawer.hasAttribute('hidden')) close();
      },
      { signal }
    );

    drawer.addEventListener(
      'keydown',
      event => {
        if (event.key !== 'Tab') return;
        const focusable = Array.from(
          drawer.querySelectorAll<HTMLElement>(
            'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
          )
        ).filter(el => el.offsetParent !== null || el === document.activeElement);
        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        if (!first || !last) return;
        if (event.shiftKey && document.activeElement === first) {
          event.preventDefault();
          last.focus();
        } else if (!event.shiftKey && document.activeElement === last) {
          event.preventDefault();
          first.focus();
        }
      },
      { signal }
    );

    function showEstado(message: string, kind: 'exito' | 'error' | null) {
      if (!estadoEl) return;
      estadoEl.textContent = message;
      estadoEl.className = 'cotizacion-estado';
      if (kind) estadoEl.classList.add(`cotizacion-estado--${kind}`);
      estadoEl.hidden = !message;
    }

    formEl?.addEventListener(
      'submit',
      async event => {
        event.preventDefault();
        if (enviando || !formEl || !submitBtn) return;
        showEstado('', null);

        if (!formEl.checkValidity()) {
          formEl.reportValidity();
          return;
        }

        const data = new FormData(formEl);
        const items = getCotizacionItems();

        enviando = true;
        submitBtn.disabled = true;
        submitBtn.textContent = i18n.enviando;

        const payload = {
          nombre: String(data.get('nombre') ?? ''),
          apellido: String(data.get('apellido') ?? ''),
          email: String(data.get('email') ?? ''),
          telefono: String(data.get('telefono') ?? ''),
          mensaje: String(data.get('mensaje') ?? ''),
          consentimiento_datos: data.get('consentimiento') === 'on',
          productos: items.map(i => ({ slug: i.slug, nombre: i.nombre, cantidad: i.cantidad })),
        };
        const institucion = String(data.get('institucion') ?? '').trim();
        if (institucion) Object.assign(payload, { institucion });

        const resultado = await submitCotizacion(payload);

        enviando = false;
        submitBtn.disabled = false;
        submitBtn.textContent = i18n.enviar;

        if (resultado.ok) {
          showEstado(i18n.exito, 'exito');
          vaciarCotizacion();
          formEl.reset();
        } else {
          showEstado(i18n.error, 'error');
        }
      },
      { signal }
    );
  }

  document.addEventListener('astro:page-load', initCotizacionDrawer);
  initCotizacionDrawer();
</script>
