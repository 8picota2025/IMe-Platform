---
// PWA Install Banner - show when logo clicked + page refreshed
---

<div id="pwa-banner" style="display:none">
  <button id="pwa-install">Instalar</button>
  <button id="pwa-close">Cerrar</button>
</div>

<script>
  const LOGO_CLICKED = 'ime_logo_clicked';
  const DISMISSED = 'ime_pwa_dismissed';
  let prompt: unknown = null;

  if ('serviceWorker' in navigator) {
    navigator.serviceWorker.register('/service-worker.js').catch(() => {});
  }

  window.addEventListener('beforeinstallprompt', (e: unknown) => {
    const event = e as { preventDefault: () => void };
    event.preventDefault();
    prompt = e;
    checkConditions();
  });

  function checkConditions() {
    if (sessionStorage.getItem(DISMISSED) === '1') return;

    // Check if page was refreshed after logo click
    const logoClicked = sessionStorage.getItem(LOGO_CLICKED) === '1';
    const isReload = performance.navigation.type === 1 ||
                     (window.performance.getEntriesByType('navigation')[0] as PerformanceNavigationTiming)?.type === 'reload';

    if (!logoClicked || !isReload) return;

    const banner = document.getElementById('pwa-banner');
    if (!banner) return;
    banner.style.display = 'block';
    sessionStorage.removeItem(LOGO_CLICKED);

    document.getElementById('pwa-install')?.addEventListener('click', () => {
      const p = prompt as { prompt: () => void; userChoice: Promise<unknown> };
      p?.prompt?.();
      p?.userChoice?.then(() => {
        banner.style.display = 'none';
        sessionStorage.setItem(DISMISSED, '1');
      });
    });

    document.getElementById('pwa-close')?.addEventListener('click', () => {
      banner.style.display = 'none';
      sessionStorage.setItem(DISMISSED, '1');
    });
  }

  // Detect logo click
  function initLogoListener() {
    const logos = document.querySelectorAll('a[href="/"], a[href="/es/"], .navbar__logo, [class*="logo"]');
    logos.forEach(logo => {
      logo.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).closest('[class*="logo"]')) {
          sessionStorage.setItem(LOGO_CLICKED, '1');
        }
      });
    });
  }

  if (document.readyState !== 'loading') {
    initLogoListener();
    checkConditions();
  } else {
    document.addEventListener('DOMContentLoaded', () => {
      initLogoListener();
      checkConditions();
    });
  }
</script>
