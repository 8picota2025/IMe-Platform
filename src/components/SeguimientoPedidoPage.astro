---
import Layout from '../layouts/Layout.astro';
import { buildCanonical, buildPageTitle } from '../lib/seo';
import type { Locale } from '../i18n/utils';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const isEn = locale === 'en';
const copy = {
  title: isEn ? 'Order tracking' : 'Seguimiento de pedido',
  description: isEn
    ? 'Check the status of a confirmed order, quote or after-sales request with your reference and contact email.'
    : 'Consulte el estado de un pedido, cotización o solicitud posventa con su referencia y correo de contacto.',
  badge: isEn ? 'After-sales' : 'Posventa',
  ref: isEn ? 'Order or quote reference' : 'Referencia de pedido o cotización',
  email: isEn ? 'Contact email' : 'Correo de contacto',
  submit: isEn ? 'Request status' : 'Solicitar estado',
  helper: isEn
    ? 'If the order is not yet connected to automatic tracking, an I-ME advisor will validate the reference and reply through the official channel.'
    : 'Si el pedido aún no está conectado al seguimiento automático, un asesor I-ME validará la referencia y responderá por el canal oficial.',
  statesTitle: isEn ? 'Operational states' : 'Estados operativos',
  states: isEn
    ? [
        'Received',
        'Payment validated',
        'In preparation',
        'Dispatched',
        'Delivered',
        'Delayed',
        'Cancelled',
      ]
    : [
        'Recibido',
        'Pago validado',
        'En preparación',
        'Despachado',
        'Entregado',
        'Retrasado',
        'Cancelado',
      ],
};
---

<Layout
  title={buildPageTitle(copy.title)}
  description={copy.description}
  canonical={buildCanonical(currentPath)}
  locale={locale}
  currentPath={currentPath}
>
  <section class="commerce-route container">
    <span class="section-tag">{copy.badge}</span>
    <h1>{copy.title}</h1>
    <p>{copy.description}</p>

    <form class="commerce-route__form" data-order-tracking-form>
      <label>
        <span>{copy.ref}</span>
        <input name="reference" autocomplete="off" required />
      </label>
      <label>
        <span>{copy.email}</span>
        <input name="email" type="email" autocomplete="email" required />
      </label>
      <button class="btn btn-primary" type="submit">{copy.submit}</button>
    </form>

    <p class="commerce-route__helper">{copy.helper}</p>

    <section class="commerce-route__states" aria-labelledby="order-states-title">
      <h2 id="order-states-title">{copy.statesTitle}</h2>
      <ol>
        {copy.states.map(state => <li>{state}</li>)}
      </ol>
    </section>
  </section>

  <script is:inline define:vars={{ isEn }}>
    const form = document.querySelector('[data-order-tracking-form]');
    form?.addEventListener('submit', event => {
      event.preventDefault();
      const data = new FormData(form);
      const reference = String(data.get('reference') || '').trim();
      const email = String(data.get('email') || '').trim();
      const text = isEn
        ? `Hello I-ME, I want to check order/quote status. Reference: ${reference}. Email: ${email}.`
        : `Hola I-ME, quiero consultar el estado de mi pedido/cotización. Referencia: ${reference}. Correo: ${email}.`;
      window.location.href = `https://wa.me/573138674059?text=${encodeURIComponent(text)}`;
    });
  </script>
</Layout>

<style>
  .commerce-route {
    padding-block: clamp(3rem, 8vw, 6rem);
  }
  .commerce-route h1 {
    max-width: 760px;
    margin: 0.4rem 0 1rem;
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5vw, 4rem);
    line-height: 0.95;
    color: var(--ink);
  }
  .commerce-route p {
    max-width: 720px;
    color: var(--text-mid);
    font-size: 1rem;
    line-height: 1.7;
  }
  .commerce-route__form {
    display: grid;
    gap: 1rem;
    max-width: 620px;
    margin-block: 1.5rem;
  }
  .commerce-route__form label {
    display: grid;
    gap: 0.4rem;
    color: var(--ink);
    font-weight: 700;
  }
  .commerce-route__form input {
    width: 100%;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.9rem 1rem;
    color: var(--ink);
    background: var(--white);
  }
  .commerce-route__helper,
  .commerce-route__states {
    max-width: 760px;
    padding: 1rem 1.1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--off);
  }
  .commerce-route__states {
    margin-block-start: 1rem;
  }
  .commerce-route__states h2 {
    margin: 0 0 0.75rem;
    font-size: var(--step-0);
    color: var(--ink);
  }
  .commerce-route__states ol {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .commerce-route__states li {
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    background: var(--white);
    color: var(--text-mid);
  }
</style>
