---
/**
 * SimuladorFinanciero — calcula cuota mensual orientativa con PMT.
 * Tasa: financiacion.tasa_anual (actualmente 12% EA).
 * El monto del slider es el importe a financiar (50% restante tras anticipo).
 */
import { t, type Locale } from '../i18n/utils';
import financiacion from '../data/financiacion.json';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const contactoHref = locale === 'en' ? '/en/contact' : '/es/contacto';
const whatsappUrl = 'https://wa.me/573138674059';

const config = {
  locale,
  montoMin: financiacion.monto_min,
  montoMax: financiacion.monto_max,
  montoPaso: financiacion.monto_paso,
  montoSugerido: financiacion.monto_sugerido,
  plazos: financiacion.plazos_meses,
  tasaAnual: financiacion.tasa_anual,
  i18n: {
    monto: t(locale, 'financiacion.simulador_monto'),
    plazo: t(locale, 'financiacion.simulador_plazo'),
    meses: t(locale, 'financiacion.meses'),
    calcular: t(locale, 'financiacion.calcular'),
    resultado: t(locale, 'financiacion.simulador_resultado'),
    ctaPersonalizada: t(locale, 'financiacion.cta_personalizada'),
    ctaWhatsapp: t(locale, 'financiacion.cta_whatsapp'),
    ctaCotizacion: t(locale, 'financiacion.cta_cotizacion'),
  },
  contactoHref,
  whatsappUrl,
};

const labelTotal = locale === 'es' ? 'Total a pagar' : 'Total to pay';
const labelTasa =
  locale === 'es'
    ? `Tasa referencial ${financiacion.tasa_anual}% EA · Simulación orientativa, sujeta a evaluación.`
    : `Reference rate ${financiacion.tasa_anual}% EA · Indicative simulation, subject to evaluation.`;
---

<section
  class="simulador"
  aria-labelledby="simulador-titulo"
  data-simulador-config={JSON.stringify(config)}
>
  <h2 id="simulador-titulo">{t(locale, 'financiacion.simulador_titulo')}</h2>
  <p class="simulador__desc">{t(locale, 'financiacion.simulador_desc')}</p>

  <form id="simulador-form" class="simulador__form">
    <div class="simulador__field">
      <label for="simulador-monto">
        {config.i18n.monto} ({t(locale, 'financiacion.moneda_cop')})
      </label>
      <input
        type="range"
        id="simulador-monto-rango"
        min={config.montoMin}
        max={config.montoMax}
        step={config.montoPaso}
        value={config.montoSugerido}
        aria-describedby="simulador-monto-valor"
      />
      <input
        type="number"
        id="simulador-monto"
        name="monto"
        min={config.montoMin}
        max={config.montoMax}
        step={config.montoPaso}
        value={config.montoSugerido}
        inputmode="numeric"
      />
      <output id="simulador-monto-valor" for="simulador-monto-rango simulador-monto"></output>
    </div>

    <div class="simulador__field">
      <label for="simulador-plazo">{config.i18n.plazo}</label>
      <select id="simulador-plazo" name="plazo">
        {
          config.plazos.map(meses => (
            <option value={meses}>
              {meses} {config.i18n.meses}
            </option>
          ))
        }
      </select>
    </div>

    <button type="submit" class="btn btn-primary">{config.i18n.calcular}</button>
  </form>

  <div
    id="simulador-resultado"
    class="simulador__resultado"
    role="status"
    aria-live="polite"
    hidden
  >
    <div class="simulador__numeros">
      <div class="simulador__numero-main">
        <span class="simulador__numero-label">{config.i18n.resultado}</span>
        <strong class="simulador__numero-valor" id="resultado-cuota">—</strong>
      </div>
      <div class="simulador__numero-sec">
        <span class="simulador__numero-label">{labelTotal}</span>
        <span class="simulador__numero-valor" id="resultado-total">—</span>
      </div>
    </div>
    <p class="simulador__tasa-nota">{labelTasa}</p>
    <div class="simulador__cta">
      <a href={config.contactoHref} class="btn btn-primary">{config.i18n.ctaPersonalizada}</a>
      <a
        href={config.whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-secondary">{config.i18n.ctaWhatsapp}</a
      >
      <button type="button" id="simulador-cta-cotizacion" class="btn btn-secondary"
        >{config.i18n.ctaCotizacion}</button
      >
    </div>
  </div>

  <p class="simulador__aviso" role="note">{t(locale, 'financiacion.simulador_aviso')}</p>
</section>

<style>
  .simulador {
    background: var(--off);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    margin-block-end: var(--space-xl);
  }
  .simulador h2 {
    margin: 0 0 0.5rem;
    font-size: var(--step-1);
  }
  .simulador__desc {
    color: var(--text-mid);
    margin: 0 0 1.25rem;
    max-width: 640px;
  }
  .simulador__form {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    gap: 1.25rem;
    margin-block-end: 1.25rem;
  }
  .simulador__field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    min-width: 220px;
    flex: 1;
  }
  .simulador__field label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-mid);
  }
  .simulador__field input,
  .simulador__field select {
    padding: 0.55rem 0.7rem;
    border: 1px solid var(--border-mid);
    border-radius: 8px;
    font-size: 0.9rem;
    background: var(--white);
    color: var(--ink);
    font-family: inherit;
  }
  .simulador__field input[type='range'] {
    padding: 0;
    border: none;
    background: transparent;
    accent-color: var(--t800);
  }
  .simulador__field output {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--t900);
  }
  .simulador__resultado {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
    margin-block-end: 1.25rem;
  }
  .simulador__resultado[hidden] {
    display: none;
  }
  .simulador__numeros {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-block-end: 0.75rem;
  }
  .simulador__numero-main {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    flex: 2;
    min-width: 180px;
  }
  .simulador__numero-sec {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    flex: 1;
    min-width: 140px;
  }
  .simulador__numero-label {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-mid);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .simulador__numero-valor {
    font-size: var(--step-1);
    font-weight: 700;
    color: var(--t900);
  }
  .simulador__numero-main .simulador__numero-valor {
    font-size: var(--step-2);
    color: var(--ink);
  }
  .simulador__tasa-nota {
    font-size: 0.78rem;
    color: var(--text-muted);
    margin: 0 0 1rem;
  }
  .simulador__cta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .simulador__aviso {
    font-size: 0.78rem;
    color: var(--text-mid);
    margin: 0;
    border-top: 1px solid var(--border);
    padding-top: 1rem;
  }
</style>

<script>
  import { formatMoneda } from '../lib/format';
  import { abrirCotizacion } from '../lib/cotizacion-equipos';
  import { getLocale } from '../i18n/utils';

  interface SimuladorConfig {
    locale: 'es' | 'en';
    tasaAnual: number;
  }

  function initSimulador() {
    const section = document.querySelector<HTMLElement>('.simulador');
    if (!section || section.dataset['simuladorBound'] === 'true') return;
    section.dataset['simuladorBound'] = 'true';

    const config = JSON.parse(section.dataset['simuladorConfig'] ?? '{}') as SimuladorConfig;
    const locale = config.locale ?? getLocale(window.location.pathname);
    const tasaAnual = config.tasaAnual ?? 12;

    const form = document.getElementById('simulador-form') as HTMLFormElement | null;
    const rango = document.getElementById('simulador-monto-rango') as HTMLInputElement | null;
    const numero = document.getElementById('simulador-monto') as HTMLInputElement | null;
    const valor = document.getElementById('simulador-monto-valor');
    const resultado = document.getElementById('simulador-resultado');
    const cotizacionBtn = document.getElementById('simulador-cta-cotizacion');

    function actualizarValor() {
      if (!numero || !valor) return;
      valor.textContent = formatMoneda(Number(numero.value), 'COP', locale) ?? '';
    }

    rango?.addEventListener('input', () => {
      if (!numero || !rango) return;
      numero.value = rango.value;
      actualizarValor();
    });
    numero?.addEventListener('input', () => {
      if (!numero || !rango) return;
      rango.value = numero.value;
      actualizarValor();
    });
    actualizarValor();

    form?.addEventListener('submit', event => {
      event.preventDefault();
      if (!resultado) return;

      const monto = Number(numero?.value ?? 0);
      const plazoEl = document.getElementById('simulador-plazo') as HTMLSelectElement | null;
      const n = Number(plazoEl?.value ?? 12);
      const r = tasaAnual / 100 / 12;

      const pow = Math.pow(1 + r, n);
      const cuota = (monto * r * pow) / (pow - 1);
      const total = cuota * n;

      const cuotaEl = document.getElementById('resultado-cuota');
      const totalEl = document.getElementById('resultado-total');
      if (cuotaEl) cuotaEl.textContent = formatMoneda(Math.round(cuota), 'COP', locale) ?? '';
      if (totalEl) totalEl.textContent = formatMoneda(Math.round(total), 'COP', locale) ?? '';

      resultado.hidden = false;
      resultado.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });

    cotizacionBtn?.addEventListener('click', () => abrirCotizacion());
  }

  document.addEventListener('astro:page-load', initSimulador);
  initSimulador();
</script>
