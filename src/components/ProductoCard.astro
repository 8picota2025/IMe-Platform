---
/**
 * ProductoCard — tarjeta de producto reutilizable para catálogo,
 * landings (relacionados) y home (destacados).
 * Solo datos reales: badges, precio y CTA dependen de los campos provistos.
 */
import { t, type Locale } from '../i18n/utils';
import { formatMoneda } from '../lib/format';

interface ProductoCardData {
  slug: string;
  nombre: string;
  descripcion_corta: string;
  imagen_principal: string | null;
  destacado: boolean;
  nuevo: boolean;
  familia: { slug: string; nombre: string };
  /** Campos adicionales para filtrado en cliente (catálogo). */
  tipo_comercial?: string;
  texto_busqueda?: string;
  especificaciones_reducidas?: Record<string, string>;
  /** Campos comerciales para los CTA de carrito/cotización (F4). */
  precio?: number | null;
  moneda?: string;
  stock?: number | null;
  /** Escenario A: disponibilidad en tiempo real provista por el proveedor. */
  disponible?: boolean;
  fulfillment_mode?: 'dropship' | 'cotizacion' | 'individualizado';
}

interface Props {
  producto: ProductoCardData;
  locale: Locale;
  /** Habilita el checkbox de comparación (catálogo). */
  comparable?: boolean;
}

const { producto, locale, comparable = false } = Astro.props;
const segment = locale === 'en' ? 'products' : 'productos';
const href = `/${locale}/${segment}/${producto.slug}`;
const noDisponible = producto.disponible === false;
const precioFormateado = formatMoneda(producto.precio ?? null, producto.moneda ?? 'COP', locale);
const whatsappHref = `https://wa.me/573138674059?text=${encodeURIComponent(
  `${t(locale, 'producto.cta_consultar_disponibilidad')}: ${producto.nombre}`
)}`;

function modalidadLabel(modalidad?: string): string {
  if (modalidad === 'dropship') return locale === 'en' ? 'Dropship' : 'Dropship';
  if (modalidad === 'individualizado') return locale === 'en' ? 'Custom order' : 'A medida';
  return locale === 'en' ? 'Quotation' : 'Cotización';
}
---

<li
  class="card producto-card"
  data-producto-slug={producto.slug}
  data-nombre={producto.nombre}
  data-imagen={producto.imagen_principal ?? ''}
  data-familia={producto.familia.slug}
  data-familia-nombre={producto.familia.nombre}
  data-comercial={producto.tipo_comercial ?? ''}
  data-fulfillment={producto.fulfillment_mode ?? ''}
  data-disponible={producto.disponible === false ? '0' : '1'}
  data-destacado={producto.destacado ? '1' : '0'}
  data-nuevo={producto.nuevo ? '1' : '0'}
  data-busqueda={producto.texto_busqueda ?? ''}
  data-specs={JSON.stringify(producto.especificaciones_reducidas ?? {})}
  data-precio={producto.precio ?? ''}
  data-moneda={producto.moneda ?? 'COP'}
  data-stock={producto.stock ?? ''}
  data-href={href}
>
  <a
    href={href}
    class="producto-card__link"
    aria-label={`${t(locale, 'catalogo.ver_detalle')}: ${producto.nombre}`}
  >
    <div class="producto-card__img-wrapper">
      <img
        src={producto.imagen_principal ?? '/assets/img-placeholder.svg'}
        alt={producto.nombre}
        width="400"
        height="280"
        loading="lazy"
        decoding="async"
        class="producto-card__img"
      />
      {
        (producto.destacado || producto.nuevo || noDisponible) && (
          <div class="producto-card__badges" aria-hidden="true">
            {producto.nuevo && (
              <span class="badge badge-green">{t(locale, 'producto.badge_nuevo')}</span>
            )}
            {producto.destacado && (
              <span class="badge badge-teal">{t(locale, 'producto.badge_destacado')}</span>
            )}
            {noDisponible && (
              <span class="badge badge-gris">{t(locale, 'producto.badge_no_disponible')}</span>
            )}
          </div>
        )
      }
    </div>
    <div class="producto-card__body">
      <p class="producto-card__familia">{producto.familia.nombre}</p>
      <h3 class="producto-card__nombre">{producto.nombre}</h3>
      <p class="producto-card__desc">{producto.descripcion_corta}</p>
      <div class="producto-card__meta" aria-label={t(locale, 'producto.ficha_resumen_titulo')}>
        <div class="producto-card__meta-item">
          <span class="producto-card__meta-label">
            {
              producto.tipo_comercial === 'consumible' && precioFormateado
                ? locale === 'en'
                  ? 'From'
                  : 'Desde'
                : t(locale, 'producto.ficha_modalidad')
            }
          </span>
          <strong class="producto-card__meta-value">
            {
              producto.tipo_comercial === 'consumible' && precioFormateado
                ? precioFormateado
                : modalidadLabel(producto.fulfillment_mode)
            }
          </strong>
        </div>
        <div class="producto-card__meta-item">
          <span class="producto-card__meta-label">{t(locale, 'producto.ficha_stock')}</span>
          <strong class="producto-card__meta-value">
            {
              noDisponible || producto.stock === 0
                ? t(locale, 'producto.ficha_no_disponible')
                : producto.stock != null && producto.stock > 0
                  ? t(locale, 'carrito.stock_limitado').replace('{stock}', String(producto.stock))
                  : t(locale, 'producto.ficha_disponible')
            }
          </strong>
        </div>
      </div>
      <span class="btn btn-secondary producto-card__cta">{t(locale, 'catalogo.ver_detalle')}</span>
    </div>
  </a>
  {
    comparable && (
      <label class="producto-card__compare">
        <input
          type="checkbox"
          class="producto-card__compare-input"
          data-compare-slug={producto.slug}
        />
        <span>{t(locale, 'catalogo.comparar_anadir')}</span>
      </label>
    )
  }
  <button type="button" class="btn btn-secondary producto-card__quick" data-quick-view>
    {t(locale, 'catalogo.vista_rapida')}
  </button>
  {
    /* Productos con precio → carrito (dropshipping); sin precio → cotización conjunta */
    producto.precio != null && producto.precio > 0 ? (
      noDisponible ? (
        <a
          href={whatsappHref}
          class="btn btn-secondary producto-card__add"
          target="_blank"
          rel="noopener noreferrer"
        >
          {t(locale, 'producto.cta_consultar_disponibilidad')}
        </a>
      ) : (
        <button
          type="button"
          class="btn btn-secondary producto-card__add"
          aria-live="polite"
          data-add-carrito={producto.slug}
          data-nombre={producto.nombre}
          data-precio={producto.precio}
          data-moneda={producto.moneda ?? 'COP'}
          data-stock={producto.stock ?? ''}
          data-label-agregar={t(locale, 'carrito.agregar')}
          data-label-agregado={t(locale, 'carrito.agregado')}
        >
          {t(locale, 'carrito.agregar')}
        </button>
      )
    ) : (
      <button
        type="button"
        class="btn btn-secondary producto-card__add"
        aria-live="polite"
        data-add-cotizacion={producto.slug}
        data-nombre={producto.nombre}
        data-imagen={producto.imagen_principal ?? ''}
        data-label-agregar={t(locale, 'cotizacion_equipos.agregar')}
        data-label-agregado={t(locale, 'cotizacion_equipos.agregado')}
      >
        {t(locale, 'cotizacion_equipos.agregar')}
      </button>
    )
  }
</li>

<style>
  .producto-card {
    display: flex;
    flex-direction: column;
  }
  .producto-card__link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .producto-card__img-wrapper {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    aspect-ratio: 4/3;
    background: var(--off2);
  }
  .producto-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms var(--ease);
  }
  .producto-card:hover .producto-card__img {
    transform: scale(1.04);
  }
  .producto-card__badges {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    display: flex;
    gap: 0.4rem;
  }
  .producto-card__body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }
  .producto-card__familia {
    font-size: 0.7rem;
    font-weight: 700;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--t800);
    margin: 0;
  }
  .producto-card__nombre {
    font-size: 1rem;
    font-weight: 700;
    color: var(--ink);
    margin: 0;
    line-height: 1.3;
  }
  .producto-card__desc {
    font-size: 0.825rem;
    color: var(--text-mid);
    line-height: 1.5;
    margin: 0;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .producto-card__cta {
    align-self: flex-start;
    margin-block-start: 0.75rem;
    font-size: 0.8rem;
  }
  .producto-card__meta {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    padding: 0.85rem 0;
    margin-block-start: 0.25rem;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .producto-card__meta-item {
    display: grid;
    gap: 0.2rem;
  }
  .producto-card__meta-label {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    font-family: var(--font-display);
    font-weight: 700;
  }
  .producto-card__meta-value {
    font-size: 0.85rem;
    color: var(--ink);
    line-height: 1.3;
  }
  .producto-card__compare {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.25rem 1rem;
    font-size: 0.8rem;
    color: var(--text-mid);
    cursor: pointer;
  }
  .producto-card__compare-input {
    width: 1rem;
    height: 1rem;
    accent-color: var(--t800);
  }
  .producto-card__quick {
    margin: 0 1.25rem 0.75rem;
    width: calc(100% - 2.5rem);
    justify-content: center;
    font-size: 0.8rem;
    background: rgba(255, 255, 255, 0.7);
  }
  .producto-card__add {
    margin: 0 1.25rem 1.25rem;
    width: calc(100% - 2.5rem);
    justify-content: center;
    font-size: 0.8rem;
  }
  @media (max-width: 520px) {
    .producto-card__meta {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  document.addEventListener('click', event => {
    const target = event.target as HTMLElement;
    const cotizacionBtn = target.closest<HTMLButtonElement>('[data-add-cotizacion]');
    const carritoBtn = target.closest<HTMLButtonElement>('[data-add-carrito]');
    if (!cotizacionBtn && !carritoBtn) return;

    const confirmar = (btn: HTMLButtonElement) => {
      const original = btn.dataset['labelAgregar'] ?? btn.textContent ?? '';
      const agregado = btn.dataset['labelAgregado'] ?? original;
      btn.textContent = agregado;
      window.setTimeout(() => {
        btn.textContent = original;
      }, 1800);
    };

    if (cotizacionBtn) {
      const slug = cotizacionBtn.dataset['addCotizacion'];
      const nombre = cotizacionBtn.dataset['nombre'];
      const imagen = cotizacionBtn.dataset['imagen'];
      if (!slug || !nombre || !imagen) return;
      void import('../lib/cotizacion-equipos').then(({ agregarACotizacion }) => {
        agregarACotizacion({ slug, nombre, imagen });
        confirmar(cotizacionBtn);
      });
      return;
    }

    if (carritoBtn) {
      const slug = carritoBtn.dataset['addCarrito'];
      const nombre = carritoBtn.dataset['nombre'];
      const precio = Number(carritoBtn.dataset['precio']);
      const moneda = carritoBtn.dataset['moneda'] ?? 'COP';
      const stockRaw = carritoBtn.dataset['stock'];
      const stock = stockRaw ? Number(stockRaw) : null;
      if (!slug || !nombre || Number.isNaN(precio)) return;
      void import('../lib/carrito').then(({ agregarAlCarrito }) => {
        agregarAlCarrito({ slug, nombre, precio, moneda, stock });
        confirmar(carritoBtn);
      });
    }
  });
</script>
